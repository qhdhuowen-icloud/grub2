From e961f4aca26c0d45019a17d8585e90810733ac30 Mon Sep 17 00:00:00 2001
From: Fedora Ninjas <grub2-owner@fedoraproject.org>
Date: Fri, 3 Apr 2026 10:41:23 +0800
Subject: [PATCH] tlcp: export kernel symbols with EXPORT_FUNC for moddep
 resolution

The GRUB build system generates kernel_syms.lst by preprocessing
KERNEL_HEADER_FILES with -DGRUB_SYMBOL_GENERATOR=1 and extracting
EXPORT_FUNC(name) patterns. Without EXPORT_FUNC wrappers, the
5 TLCP functions were invisible to moddep, causing:

  grub_file_integrity_validation in boot is not defined

Wrap all 5 public kernel-API declarations in tlcp.h with EXPORT_FUNC().
---
 include/grub/tlcp.h | 10 +++++-----
 1 file changed, 5 insertions(+), 5 deletions(-)

diff --git a/include/grub/tlcp.h b/include/grub/tlcp.h
index bb83868..9ed7764 100644
--- a/include/grub/tlcp.h
+++ b/include/grub/tlcp.h
@@ -51,11 +51,11 @@ enum TSS2_APP_RESPONSE_CODE {
  * Public API called from boot.c
  * These functions are compiled into the GRUB kernel (not a module).
  */
-grub_err_t grub_tpm_policy_state (void);
-grub_err_t grub_file_policy_state (void);
-grub_err_t grub_tpm_integrity_validation (int halt);
-grub_err_t grub_file_integrity_validation (int halt);
-grub_err_t grub_measure_configured_files (void);
+grub_err_t EXPORT_FUNC(grub_tpm_policy_state) (void);
+grub_err_t EXPORT_FUNC(grub_file_policy_state) (void);
+grub_err_t EXPORT_FUNC(grub_tpm_integrity_validation) (int halt);
+grub_err_t EXPORT_FUNC(grub_file_integrity_validation) (int halt);
+grub_err_t EXPORT_FUNC(grub_measure_configured_files) (void);
 
 /*
  * EFI-specific helpers (implemented in kern/efi/tlcp.c).
-- 
2.47.3

