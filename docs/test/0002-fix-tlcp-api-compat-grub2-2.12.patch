From 0000000000000000000000000000000000000002 Mon Sep 17 00:00:00 2001
From: TLCP Trusted Boot <tlcp@inspur.com>
Date: Wed, 02 Apr 2026 00:00:00 +0800
Subject: [PATCH] fix TLCP API compatibility for grub2-2.12

Adapt TLCP trusted boot code to grub2-2.12 API changes:
- Rename TLCP exported functions to grub_ prefix for kernel export visibility
- Replace grub_tpm_chip_validate() with grub_tpm_present() (2.12 API)
- Fix grub_fs struct field names: label->fs_label, uuid->fs_uuid
- Fix grub_tpm_measure() call signature (4 args in 2.12, use GRUB_STRING_PCR)
- Fix grub_efi_guid_t -> grub_guid_t rename in 2.12
- Fix undefined error codes: GRUB_ERR_LOCKED, GRUB_ERR_NOT_READY
- Add grub/err.h and grub/symbol.h to tlcp.h for self-containment
- Add tlcp.h to KERNEL_HEADER_FILES for kernel symbol export
---
diff --git a/grub-core/Makefile.am b/grub-core/Makefile.am
index 7953ba9..651382c 100644
--- a/grub-core/Makefile.am
+++ b/grub-core/Makefile.am
@@ -66,6 +66,7 @@ CLEANFILES += grub_script.yy.c grub_script.yy.h
 
 include $(srcdir)/Makefile.core.am
 
+KERNEL_HEADER_FILES += $(top_srcdir)/include/grub/tlcp.h
 KERNEL_HEADER_FILES += $(top_srcdir)/include/grub/backtrace.h
 KERNEL_HEADER_FILES += $(top_srcdir)/include/grub/cache.h
 KERNEL_HEADER_FILES += $(top_srcdir)/include/grub/command.h
diff --git a/grub-core/commands/boot.c b/grub-core/commands/boot.c
index 3f5d429..a9afae1 100644
--- a/grub-core/commands/boot.c
+++ b/grub-core/commands/boot.c
@@ -231,11 +231,11 @@ grub_cmd_boot (struct grub_command *cmd __attribute__ ((unused)),
   int        policy_state = -1;
 
   (void)key;
-  measure_configured_files();
+  grub_measure_configured_files();
 
-  if(grub_tpm_chip_validate())
+  if(grub_tpm_present())
     {
-      policy_state = tpm_policy_state();
+      policy_state = grub_tpm_policy_state();
       if(policy_state == POLICY_STATE_NONE)
       {
           goto trust_end;
@@ -244,27 +244,27 @@ grub_cmd_boot (struct grub_command *cmd __attribute__ ((unused)),
       {
         if((policy_state & POLICY_STATE_CHEKC_MASK) == POLICY_STATE_AUDIT)
         {
-          tpm_integrity_validation(0);
+          grub_tpm_integrity_validation(0);
         }
         else
         {
-          tpm_integrity_validation(1);
+          grub_tpm_integrity_validation(1);
         }
       }
       else
       {
         if(((policy_state & POLICY_STATE_CHEKC_MASK) == POLICY_STATE_AUDIT) || ((policy_state & POLICY_STATE_CHEKC_MASK) == POLICY_STATE_SUPERVISORY))
         {
-          file_integrity_validation(1);
+          grub_file_integrity_validation(1);
         }
       }
     }
     else
     {
-      policy_state = file_policy_state();
+      policy_state = grub_file_policy_state();
       if(((policy_state & POLICY_STATE_CHEKC_MASK) == POLICY_STATE_AUDIT) || ((policy_state & POLICY_STATE_CHEKC_MASK) == POLICY_STATE_SUPERVISORY))
       {
-        file_integrity_validation(1);
+        grub_file_integrity_validation(1);
       }
     }
 trust_end:
diff --git a/grub-core/kern/efi/tpm2nvstorage.c b/grub-core/kern/efi/tpm2nvstorage.c
index 86a3954..1a57b66 100644
--- a/grub-core/kern/efi/tpm2nvstorage.c
+++ b/grub-core/kern/efi/tpm2nvstorage.c
@@ -184,13 +184,13 @@ again:
             Status = grub_error(GRUB_ERR_BAD_ARGUMENT, N_("TPM2 Nv Read Bad auth entity "));
             break;
         case TPM_RC_NV_LOCKED:
-            Status = grub_error (GRUB_ERR_LOCKED, N_("TPM2 Nv Locked"));
+            Status = grub_error (GRUB_ERR_ACCESS_DENIED, N_("TPM2 Nv Locked"));
             break;
         case TPM_RC_NV_RANGE:
             Status = grub_error (GRUB_ERR_OUT_OF_RANGE, N_("TPM2 Nv Read out of range"));
             break;
         case TPM_RC_NV_UNINITIALIZED:
-            Status = grub_error (GRUB_ERR_NOT_READY, N_("TPM2 Nv Uninitialized"));
+            Status = grub_error (GRUB_ERR_BAD_DEVICE, N_("TPM2 Nv Uninitialized"));
             break;
         case TPM_RC_HANDLE + RC_NV_Read_nvIndex:
             Status = grub_error (GRUB_ERR_NOT_IMPLEMENTED_YET, "TPM2 Nv Index Not Defined");
diff --git a/grub-core/kern/efi/tpm2tis.c b/grub-core/kern/efi/tpm2tis.c
index bfb3b49..f983d11 100644
--- a/grub-core/kern/efi/tpm2tis.c
+++ b/grub-core/kern/efi/tpm2tis.c
@@ -9,7 +9,7 @@
 #include <grub/tpm20.h>
 #include <grub/term.h>
 
-static grub_efi_guid_t tpm2_guid = EFI_TPM2_GUID;
+static grub_guid_t tpm2_guid = EFI_TPM2_GUID;
 
 static grub_efi_boolean_t grub_tpm2_handle_find(grub_efi_handle_t *tpm_handle,
                                                grub_efi_uint8_t *protocol_version)
@@ -65,7 +65,7 @@ grub_tpm2_submit_command(UINT32 inbufsize,
     grub_efi_status_t             status;
     grub_efi_tpm2_protocol_t      *tpm;
     grub_efi_handle_t             tpm_handle;
-    grub_efi_guid_t               guid = EFI_TPM2_GUID;
+    grub_guid_t                   guid = EFI_TPM2_GUID;
     grub_efi_handle_t             *handles;
     grub_efi_uintn_t              num_handles;
     
diff --git a/grub-core/kern/tlcp.c b/grub-core/kern/tlcp.c
index bf4beda..5f2b298 100644
--- a/grub-core/kern/tlcp.c
+++ b/grub-core/kern/tlcp.c
@@ -99,7 +99,7 @@ grub_password_get (char buf[], unsigned buf_size)
  * @return :
  * */
 grub_err_t
-tpm_policy_state(void)
+grub_tpm_policy_state(void)
 {
     int      policy_state_tpm = TSS2_APP_RC_POLICY_NOT_EXIST;
     int      policy_state_file = TSS2_APP_RC_POLICY_NOT_EXIST;
@@ -127,17 +127,17 @@ tpm_policy_state(void)
 }
 
 grub_err_t
-file_policy_state(void)
+grub_file_policy_state(void)
 {
-    int      file_policy_state = TSS2_APP_RC_POLICY_NOT_EXIST;
+    int      grub_file_policy_state = TSS2_APP_RC_POLICY_NOT_EXIST;
 
-    file_policy_state = check_file_policy_state();
-    if(file_policy_state == TSS2_APP_RC_AUDIT_POLICY_EXIST || file_policy_state == TSS2_APP_RC_SUPERVISORY_POLICY_EXIST)
+    grub_file_policy_state = check_file_policy_state();
+    if(grub_file_policy_state == TSS2_APP_RC_AUDIT_POLICY_EXIST || grub_file_policy_state == TSS2_APP_RC_SUPERVISORY_POLICY_EXIST)
     {
         return POLICY_STATE_SUPERVISORY;
     }
 
-    if(file_policy_state == TSS2_APP_RC_POLICY_NOT_EXIST)
+    if(grub_file_policy_state == TSS2_APP_RC_POLICY_NOT_EXIST)
     {
         return POLICY_STATE_NONE;
     }
@@ -628,7 +628,7 @@ file_hardware_integrity_validation(unsigned char *buf, int buf_len)
 }
 
 grub_err_t
-tpm_integrity_validation(int halt)
+grub_tpm_integrity_validation(int halt)
 {
     grub_err_t              hard_integrity = 0; //0 means well, others means not well
     grub_err_t              soft_integrity = 0;
@@ -712,7 +712,7 @@ end:
 }
 
 grub_err_t
-file_integrity_validation(int halt)
+grub_file_integrity_validation(int halt)
 {
     grub_uint64_t   endtime;
     unsigned char           *hard_buf = NULL;
@@ -837,9 +837,9 @@ grub_get_device_info (const char *name)
         fsname = "ext*";
     }
 
-    if (fs->label)
+    if (fs->fs_label)
     {
-        (fs->label) (dev, &label);
+        (fs->fs_label) (dev, &label);
         if (grub_errno == GRUB_ERR_NONE)
         {
             grub_free(label);
@@ -847,9 +847,9 @@ grub_get_device_info (const char *name)
         grub_errno = GRUB_ERR_NONE;
     }
 
-    if (fs->uuid)
+    if (fs->fs_uuid)
     {
-        (fs->uuid) (dev, &uuid);
+        (fs->fs_uuid) (dev, &uuid);
         if (grub_errno == GRUB_ERR_NONE)
         {
             if (uuid && grub_strlen(uuid)) 
@@ -1005,7 +1005,7 @@ file_measure(char *file_name)
     }
     grub_printf("\n");
 #endif
-    grub_tpm_measure (buf, len, GRUB_APPLICAION_PCR, "grub_measured_file", temp);
+    grub_tpm_measure ((unsigned char *)buf, len, GRUB_STRING_PCR, "grub_measured_file");
 
 end:
     if(buf)
@@ -1073,7 +1073,7 @@ conf_parse(char *buf, int buf_len)
 }
 
 grub_err_t
-measure_configured_files(void)
+grub_measure_configured_files(void)
 {
     grub_err_t          result = 0;
     grub_file_t         file = 0;   
@@ -1100,7 +1100,7 @@ measure_configured_files(void)
         goto end;
     }
 
-    grub_tpm_measure (buf, len, GRUB_APPLICAION_PCR, "grub_measured_file", MEASUREMENT_CONFIG_FILE);
+    grub_tpm_measure ((unsigned char *)buf, len, GRUB_STRING_PCR, "grub_measured_file");
 
     conf_parse(buf, len);
 
diff --git a/include/grub/tlcp.h b/include/grub/tlcp.h
index 2be694f..93948b5 100644
--- a/include/grub/tlcp.h
+++ b/include/grub/tlcp.h
@@ -1,6 +1,9 @@
 #ifndef GRUB_TLCP_HEADER
 #define GRUB_TLCP_HEADER 1
 
+#include <grub/err.h>
+#include <grub/symbol.h>
+
 enum TSS2_APP_RESPONSE_CODE{
     TSS2_APP_RC_BASE,
     TSS2_APP_RC_BAD_IO,
@@ -35,11 +38,11 @@ enum TSS2_APP_RESPONSE_CODE{
 #define POLICY_STATE_SUPERVISORY  (grub_err_t)(0x00000002)
 #define POLICY_STATE_TPM_CHECK    (grub_err_t)(0x00010000) //check integrity with tpm
 
-grub_err_t EXPORT_FUNC(tpm_policy_state)(void);
-grub_err_t EXPORT_FUNC(file_policy_state)(void);
-grub_err_t EXPORT_FUNC(tpm_integrity_validation)(int halt);
-grub_err_t EXPORT_FUNC(file_integrity_validation)(int halt);
-grub_err_t EXPORT_FUNC(measure_configured_files)(void);
+grub_err_t EXPORT_FUNC(grub_tpm_policy_state)(void);
+grub_err_t EXPORT_FUNC(grub_file_policy_state)(void);
+grub_err_t EXPORT_FUNC(grub_tpm_integrity_validation)(int halt);
+grub_err_t EXPORT_FUNC(grub_file_integrity_validation)(int halt);
+grub_err_t EXPORT_FUNC(grub_measure_configured_files)(void);
 #if defined (GRUB_MACHINE_EFI)
 grub_err_t check_tpm_policy_state(void);
 grub_err_t check_file_policy_state(void);
