From 992445146f7ed40174f32fe69773fcee00f7dafb Mon Sep 17 00:00:00 2001
From: Fedora Ninjas <grub2-owner@fedoraproject.org>
Date: Fri, 3 Apr 2026 10:27:10 +0800
Subject: [PATCH] tlcp: fix tlcp.h to be self-contained for GRUB symbol
 generator

Add #include <grub/err.h> and <grub/types.h> so the header can be
preprocessed standalone during kernel symbol extraction.
Replace grub_err_t casts in macro definitions with plain unsigned
integer literals to avoid type-before-include issues.
---
 include/grub/tlcp.h | 15 +++++++++------
 1 file changed, 9 insertions(+), 6 deletions(-)

diff --git a/include/grub/tlcp.h b/include/grub/tlcp.h
index a1d02e8..bb83868 100644
--- a/include/grub/tlcp.h
+++ b/include/grub/tlcp.h
@@ -6,6 +6,9 @@
 #ifndef GRUB_TLCP_HEADER
 #define GRUB_TLCP_HEADER 1
 
+#include <grub/err.h>
+#include <grub/types.h>
+
 /* Policy state error codes */
 enum TSS2_APP_RESPONSE_CODE {
     TSS2_APP_RC_BASE,
@@ -34,12 +37,12 @@ enum TSS2_APP_RESPONSE_CODE {
 };
 
 /* Policy state flags */
-#define POLICY_STATE_TPM_MASK     (grub_err_t)(0x00FF0000)
-#define POLICY_STATE_CHEKC_MASK   (grub_err_t)(0x000000FF)
-#define POLICY_STATE_NONE         (grub_err_t)(0x00000000)
-#define POLICY_STATE_AUDIT        (grub_err_t)(0x00000001)
-#define POLICY_STATE_SUPERVISORY  (grub_err_t)(0x00000002)
-#define POLICY_STATE_TPM_CHECK    (grub_err_t)(0x00010000)
+#define POLICY_STATE_TPM_MASK     0x00FF0000u
+#define POLICY_STATE_CHEKC_MASK   0x000000FFu
+#define POLICY_STATE_NONE         0x00000000u
+#define POLICY_STATE_AUDIT        0x00000001u
+#define POLICY_STATE_SUPERVISORY  0x00000002u
+#define POLICY_STATE_TPM_CHECK    0x00010000u
 
 /* TLCP application PCR for configuration file measurement */
 #define TLCP_APPLICATION_PCR      12
-- 
2.47.3

