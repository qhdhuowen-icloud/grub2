From 5d80b91532e93297edb2769213ddaee39f52cc96 Mon Sep 17 00:00:00 2001
From: Fedora Ninjas <grub2-owner@fedoraproject.org>
Date: Fri, 3 Apr 2026 10:58:13 +0800
Subject: [PATCH] tlcp: avoid grub_tpm_measure module dep; use direct EFI TCG2
 call

grub_tpm_measure() is defined in the 'tpm' module (commands/efi/tpm.c),
not the kernel. Calling it from kern/tlcp.c (kernel) causes a link-time
undefined-symbol error when grub-mkimage bundles the EFI image.

Fix: add grub_tlcp_efi_measure() to kern/efi/tlcp.c that directly uses
EFI_TCG2_PROTOCOL.hash_log_extend_event(). In kern/tlcp.c call it under
#if defined(GRUB_MACHINE_EFI); on non-EFI targets the measurement is
silently skipped.
---
 grub-core/kern/efi/tlcp.c | 57 +++++++++++++++++++++++++++++++++++++++
 grub-core/kern/tlcp.c     | 20 +++++++++-----
 2 files changed, 71 insertions(+), 6 deletions(-)

diff --git a/grub-core/kern/efi/tlcp.c b/grub-core/kern/efi/tlcp.c
index ed05b7f..d021350 100644
--- a/grub-core/kern/efi/tlcp.c
+++ b/grub-core/kern/efi/tlcp.c
@@ -22,6 +22,7 @@
 #include <grub/efi/tpm2startup.h>
 #include <grub/efi/tpm2enhancedauthorization.h>
 #include <grub/tpm20.h>
+#include <grub/tpm.h>
 #include <grub/tlcp.h>
 #include <grub/file.h>
 #include <grub/mm.h>
@@ -679,3 +680,59 @@ flush:
 end:
     return result;
 }
+
+/*
+ * grub_tlcp_efi_measure - extend a buffer into a TPM2 PCR via EFI TCG2 protocol.
+ *
+ * This is the EFI platform implementation called by grub_measure_configured_files()
+ * in kern/tlcp.c.  Mirrors the logic in commands/efi/tpm.c:grub_tpm_measure()
+ * but lives in the kernel so it is available without loading the tpm module.
+ */
+grub_err_t
+grub_tlcp_efi_measure (unsigned char *buf, grub_size_t size,
+                       grub_uint8_t pcr, const char *description)
+{
+    static grub_guid_t         tpm2_guid = EFI_TPM2_GUID;
+    grub_efi_handle_t          *handles;
+    grub_efi_uintn_t           num_handles;
+    grub_efi_handle_t          tpm_handle;
+    grub_efi_tpm2_protocol_t   *tpm;
+    EFI_TCG2_EVENT             *event;
+    grub_efi_status_t          status;
+    grub_size_t                desc_len;
+
+    handles = grub_efi_locate_handle (GRUB_EFI_BY_PROTOCOL, &tpm2_guid,
+                                      NULL, &num_handles);
+    if (!handles || num_handles == 0)
+        return GRUB_ERR_NONE;   /* TPM absent — silently skip */
+
+    tpm_handle = handles[0];
+    grub_free (handles);
+
+    tpm = grub_efi_open_protocol (tpm_handle, &tpm2_guid,
+                                  GRUB_EFI_OPEN_PROTOCOL_GET_PROTOCOL);
+    if (!tpm)
+        return GRUB_ERR_NONE;
+
+    desc_len = grub_strlen (description);
+    event = grub_zalloc (sizeof (EFI_TCG2_EVENT) + desc_len + 1);
+    if (!event)
+        return grub_error (GRUB_ERR_OUT_OF_MEMORY,
+                           "cannot allocate TPM event buffer");
+
+    event->Header.HeaderSize    = sizeof (EFI_TCG2_EVENT_HEADER);
+    event->Header.HeaderVersion = 1;
+    event->Header.PCRIndex      = pcr;
+    event->Header.EventType     = EV_IPL;
+    event->Size = sizeof (*event) - sizeof (event->Event) + desc_len + 1;
+    grub_strcpy ((char *) event->Event, description);
+
+    status = tpm->hash_log_extend_event (tpm, 0, (grub_addr_t) buf,
+                                         (grub_uint64_t) size, event);
+    grub_free (event);
+
+    if (status != GRUB_EFI_SUCCESS)
+        return grub_error (GRUB_ERR_IO, "TPM2 hash_log_extend_event failed");
+
+    return GRUB_ERR_NONE;
+}
diff --git a/grub-core/kern/tlcp.c b/grub-core/kern/tlcp.c
index 0286a94..3898e6e 100644
--- a/grub-core/kern/tlcp.c
+++ b/grub-core/kern/tlcp.c
@@ -24,13 +24,18 @@
 #include <grub/i18n.h>
 #include <grub/misc.h>
 #include <grub/mm.h>
-#include <grub/tpm.h>
 #include <grub/tlcp.h>
 #include <grub/term.h>
 #include <grub/tlcp_sha256.h>
 #include <grub/tlcp_aes.h>
 #include <grub/file.h>
 
+/* EFI-specific PCR measurement helper (kern/efi/tlcp.c) */
+#if defined (GRUB_MACHINE_EFI)
+grub_err_t grub_tlcp_efi_measure (unsigned char *buf, grub_size_t size,
+                                   grub_uint8_t pcr, const char *description);
+#endif
+
 #define DEFAULT_KEY_LEN     128
 #define HARDINFO            "INSPUR__HARDWARE"
 #define SOFTINFO            "INSPUR__SOFTWARE"
@@ -629,12 +634,15 @@ grub_measure_configured_files (void)
 
     /*
      * Extend the raw file content into PCR 12 (TLCP_APPLICATION_PCR).
-     * grub_tpm_measure() hashes buf with SHA256/SM3 and calls
-     * EFI_TCG2_PROTOCOL.hash_log_extend_event() internally.
+     * grub_tlcp_efi_measure() is implemented in kern/efi/tlcp.c using the
+     * EFI TCG2 protocol directly (avoids depending on the tpm module).
+     * On non-EFI platforms this is a no-op.
      */
-    grub_tpm_measure ((unsigned char *)buf, (grub_size_t)len,
-                      TLCP_APPLICATION_PCR,
-                      "iTrustMidware:host_st_configure.xml");
+#if defined (GRUB_MACHINE_EFI)
+    grub_tlcp_efi_measure ((unsigned char *)buf, (grub_size_t)len,
+                           TLCP_APPLICATION_PCR,
+                           "iTrustMidware:host_st_configure.xml");
+#endif
 
 end:
     if (buf)  grub_free (buf);
-- 
2.47.3

