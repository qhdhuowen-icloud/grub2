From d58cc215ebc4f40d20e559b49946da2e751d3c82 Mon Sep 17 00:00:00 2001
From: Fedora Ninjas <grub2-owner@fedoraproject.org>
Date: Fri, 3 Apr 2026 10:50:39 +0800
Subject: [PATCH] tlcp: replace efi_call_X macros with direct calls in
 tpm2tis.c

grub2-2.12 removed the efi_call_X() wrappers. EFI protocol method
pointers are declared with __grub_efi_api attribute for calling
convention, so direct calls work correctly:

  efi_call_2(tpm->get_capability, tpm, &caps)
  -> tpm->get_capability(tpm, &caps)

  efi_call_5(tpm->submit_command, tpm, in, ...)
  -> tpm->submit_command(tpm, in, ...)
---
 grub-core/kern/efi/tpm2tis.c | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

diff --git a/grub-core/kern/efi/tpm2tis.c b/grub-core/kern/efi/tpm2tis.c
index f08cf9b..5d68536 100644
--- a/grub-core/kern/efi/tpm2tis.c
+++ b/grub-core/kern/efi/tpm2tis.c
@@ -48,7 +48,7 @@ grub_tpm2_present(void)
 
     caps.Size = (grub_uint8_t)sizeof(caps);
 
-    status = efi_call_2(tpm->get_capability, tpm, &caps);
+    status = tpm->get_capability(tpm, &caps);
 
     if(status != GRUB_EFI_SUCCESS || !caps.TPMPresentFlag)
     {
@@ -103,9 +103,9 @@ grub_tpm2_submit_command(UINT32 inbufsize,
     }
     grub_printf("\n");
 #endif
-    status = efi_call_5(tpm->submit_command, tpm,
-                          inbufsize, inbuf,
-                          outbufsize, outbuf);
+    status = tpm->submit_command(tpm,
+                                  inbufsize, inbuf,
+                                  outbufsize, outbuf);
 #if 0
     grub_printf("outbufsize:0x%.2x\n", outbufsize);
     grub_printf("-------------------------------grub_tpm2_submit_command------------------------------\n");
-- 
