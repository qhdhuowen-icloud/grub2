index 0000000..8d25ce0
--- /dev/null
+++ b/grub-core/kern/efi/tpm2_util/tpm2unmarshal_BASES.c
@@ -0,0 +1,46 @@
+#include <grub/err.h>
+#include <grub/misc.h>
+#include <grub/i18n.h>
+#include <grub/types.h>
+#include <grub/tpm20.h>
+#include <grub/efi/tpm2/tpm2unmarshal_BASES.h>
+
+grub_size_t grub_tpm2_unmarshal_uint8(UINT8 *in, UINT8 *value)
+{
+    if(!value)
+    {
+        return 0;
+    }
+    *value = *in;
+    return sizeof(UINT8);
+}
+
+grub_size_t grub_tpm2_unmarshal_uint16(UINT8 *in, UINT16 *value)
+{
+    if(!value)
+    {
+        return 0;
+    }
+    *value = grub_swap_bytes16(grub_get_unaligned16(in));
+    return sizeof(UINT16);
+}
+
+grub_size_t grub_tpm2_unmarshal_uint32(UINT8 *in, UINT32 *value)
+{
+    if(!value)
+    {
+        return 0;
+    }
+    *value = grub_swap_bytes32(grub_get_unaligned32(in));
+    return sizeof(UINT32);
+}
+
+grub_size_t grub_tpm2_unmarshal_uint64(UINT8 *in, UINT64 *value)
+{
+    if(!value)
+    {
+        return 0;
+    }
+    *value = grub_swap_bytes64(grub_get_unaligned64(in));
+    return sizeof(UINT64);
+}
