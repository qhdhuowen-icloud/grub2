+grub_tpm2_unseal(TPMI_DH_OBJECT             ItemHandle,
+                 TPMS_AUTH_COMMAND          *AuthSession,
+                 TPM2B_SENSITIVE_DATA       *OutData)
+{
+    grub_efi_status_t              Status;
+    TPM2_UNSEAL_COMMAND            SendBuffer;
+    TPM2_UNSEAL_RESPONSE           RecvBuffer;
+    UINT32                         SendBufferSize;
+    UINT32                         RecvBufferSize;
+    UINT32                         ResponseCode;
+    UINT8                          *Buffer;
+    UINT32                         SessionInfoSize;
+
+    SendBuffer.Header.tag = grub_swap_bytes16(TPM_ST_SESSIONS);
+    SendBuffer.Header.commandCode = grub_swap_bytes32(TPM_CC_Unseal);
+    
+    SendBuffer.ItemHandle = grub_swap_bytes32(ItemHandle);
+    
+    Buffer = (UINT8 *)&SendBuffer.AuthSession;
+    SessionInfoSize = grub_tpm2_copy_auth_session_command(AuthSession, Buffer);
+    Buffer += SessionInfoSize;
+    SendBuffer.AuthSessionSize = grub_swap_bytes32(SessionInfoSize);
+
+    SendBufferSize = (UINT32)(Buffer - (UINT8 *)&SendBuffer);
+    SendBuffer.Header.paramSize = grub_swap_bytes32(SendBufferSize);
+
+    RecvBufferSize = sizeof(RecvBuffer);
+    Status = grub_tpm2_submit_command(SendBufferSize, (UINT8 *)&SendBuffer, RecvBufferSize, (UINT8 *)&RecvBuffer);
+    if(Status)
+    {
+        return Status;
+    }
+    
+    ResponseCode = grub_swap_bytes32(RecvBuffer.Header.responseCode);
+    
+    switch(ResponseCode)
+    {
+        case TPM_RC_SUCCESS:
+            Status = grub_error(GRUB_ERR_NONE, N_("TPM2 Success"));      
+            break;
+        case TPM_RC_HANDLE + RC_Unseal_itemHandle:
+            Status = grub_error(GRUB_ERR_NOT_IMPLEMENTED_YET, N_("TPM2 Object Not Created"));
+            break;
+        case TPM_RC_TYPE + RC_Unseal_itemHandle:
+            Status = grub_error(GRUB_ERR_BAD_ARGUMENT, N_("TPM2 Wrong Type Object"));
+            break;
+        case TPM_RC_ATTRIBUTES + RC_Unseal_itemHandle:
+            Status = grub_error(GRUB_ERR_BAD_ARGUMENT, N_("TPM2 Wrong Type Object"));
+            break;
+        case TPM_RC_BAD_AUTH + RC_Unseal_itemHandle + TPM_RC_S:
+            Status = grub_error(GRUB_ERR_ACCESS_DENIED, N_("TPM2 Unseal Bad Auth"));
+            break;
+        case TPM_RC_AUTH_FAIL + RC_Unseal_itemHandle + TPM_RC_S:
+            Status = grub_error(GRUB_ERR_ACCESS_DENIED, N_("TPM2 Unseal Auth Fail"));
