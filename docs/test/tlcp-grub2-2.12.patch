+} TPM2_NV_READ_COMMAND;
+
+typedef struct {
+    TPM2_RESPONSE_HEADER        Header;
+    UINT32                      AuthSessionSize;
+    TPM2B_MAX_BUFFER            Data;
+    TPMS_AUTH_RESPONSE          AuthSession;
+} TPM2_NV_READ_RESPONSE;
+#pragma pack()
+
+grub_err_t
+grub_tpm2_nv_read_public(TPMI_RH_NV_INDEX         NvIndex,
+                         TPM2B_NV_PUBLIC          *NvPublic,
+                         TPM2B_NAME               *NvName)
+{
+    grub_efi_status_t              Status;
+    TPM2_NV_READPUBLIC_COMMAND     SendBuffer;
+    TPM2_NV_READPUBLIC_RESPONSE    RecvBuffer;
+    UINT32                         SendBufferSize;
+    UINT32                         RecvBufferSize;
+    UINT16                         NvPublicSize;
+    UINT16                         NvNameSize;
+    UINT8                          *Buffer;
+    TPM_RC                         ResponseCode;
+
+    SendBuffer.Header.tag = grub_swap_bytes16(TPM_ST_NO_SESSIONS);
+    SendBuffer.Header.commandCode = grub_swap_bytes32(TPM_CC_NV_ReadPublic);
+ 
+    SendBuffer.NvIndex = grub_swap_bytes32(NvIndex);
+    SendBufferSize = (UINT32) sizeof(SendBuffer);
+    SendBuffer.Header.paramSize = grub_swap_bytes32(SendBufferSize);
+
+    RecvBufferSize = sizeof(RecvBuffer);
+    Status = grub_tpm2_submit_command(SendBufferSize, (UINT8 *)&SendBuffer, RecvBufferSize, (UINT8 *)&RecvBuffer);
+    if(Status)                                                                                                      
+    {                                                                                                               
+        return Status;                                                                                              
+    }                                                                                                               
+                                                                                                                    
+    if(RecvBufferSize < sizeof(TPM2_RESPONSE_HEADER))                                                               
+    {                                                                                                               
+        return grub_error(GRUB_ERR_UNKNOWN_DEVICE, N_("TPM2 Device error"));                                        
+    }
+
+    ResponseCode = grub_swap_bytes32(RecvBuffer.Header.responseCode);
+    switch (ResponseCode) 
+    {
+        case TPM_RC_SUCCESS:
+            break;
+        case TPM_RC_HANDLE:
+            return grub_error (GRUB_ERR_NOT_IMPLEMENTED_YET, "TPM2 Nv Index Not Defined");
+        default:
+            return grub_error(GRUB_ERR_IO, N_("Command failed"));
+    }
+
+    NvPublicSize = grub_swap_bytes16(RecvBuffer.NvPublic.size);
+    if (NvPublicSize > sizeof(TPMS_NV_PUBLIC))
+    {
+        return grub_error(GRUB_ERR_BAD_DEVICE, N_("TPM2 Device response error"));
+    }
+
+    NvNameSize = grub_swap_bytes16(grub_get_unaligned16((&RecvBuffer + sizeof(TPM2_RESPONSE_HEADER) + sizeof(UINT16) + NvPublicSize)));
+    if (NvNameSize > sizeof(TPMU_NAME))
+    {
+        return grub_error(GRUB_ERR_BAD_DEVICE, N_("TPM2 Device response error"));
+    }  
+    
+    grub_memcpy(NvPublic, &RecvBuffer.NvPublic, sizeof(UINT16) + NvPublicSize);
+    NvPublic->size = NvPublicSize;
+    NvPublic->nvPublic.nvIndex = grub_swap_bytes32(NvPublic->nvPublic.nvIndex);
+    NvPublic->nvPublic.nameAlg = grub_swap_bytes16(NvPublic->nvPublic.nameAlg);
+    grub_set_unaligned32(&NvPublic->nvPublic.attributes, grub_swap_bytes32(grub_get_unaligned32(&NvPublic->nvPublic.attributes)));
+    NvPublic->nvPublic.authPolicy.size = grub_swap_bytes16(NvPublic->nvPublic.authPolicy.size);
+    Buffer = (UINT8 *)&RecvBuffer.NvPublic.nvPublic.authPolicy;
+    Buffer += sizeof(UINT16) + NvPublic->nvPublic.authPolicy.size;
+    NvPublic->nvPublic.dataSize = grub_swap_bytes16(grub_get_unaligned16(Buffer));
+
+    grub_memcpy(NvName->name, (UINT8 *)&RecvBuffer + sizeof(TPM2_RESPONSE_HEADER) + sizeof(UINT16) + NvPublicSize + sizeof(UINT16), NvNameSize);
+    NvName->size = NvNameSize;
+
+    return 0;
+}
+
+grub_err_t
+grub_tpm2_nv_read(TPMI_RH_NV_AUTH       AuthHandle,
+                  TPMI_RH_NV_INDEX      NvIndex,
+                  TPMS_AUTH_COMMAND     *AuthSession,
+                  UINT16                Size,
+                  UINT16                Offset,
+                  TPM2B_MAX_BUFFER      *OutData)
+{
+    grub_efi_status_t        Status;
+    TPM2_NV_READ_COMMAND     SendBuffer;
+    TPM2_NV_READ_RESPONSE    RecvBuffer;
+    UINT32                   SendBufferSize;
+    UINT32                   RecvBufferSize;
+    UINT8                    *Buffer;
+    UINT32                   SessionInfoSize;
+    TPM_RC                   ResponseCode;
+
+    SendBuffer.Header.tag = grub_swap_bytes16(TPM_ST_SESSIONS);
+    SendBuffer.Header.commandCode = grub_swap_bytes32(TPM_CC_NV_Read);
+
+    SendBuffer.AuthHandle = grub_swap_bytes32(AuthHandle);
+    SendBuffer.NvIndex = grub_swap_bytes32(NvIndex);
+    
+    Buffer = (UINT8 *)&SendBuffer.AuthSession;
+
+    // sessionInfoSize
+    SessionInfoSize = grub_tpm2_copy_auth_session_command(AuthSession, Buffer);
+    Buffer += SessionInfoSize;
+    SendBuffer.AuthSessionSize = grub_swap_bytes32(SessionInfoSize);
+
+    grub_set_unaligned16(Buffer, grub_swap_bytes16(Size));
+    Buffer += sizeof(UINT16);
+    grub_set_unaligned16(Buffer, grub_swap_bytes16(Offset));
+    Buffer += sizeof(UINT16);
+
+    SendBufferSize = (UINT32)(Buffer - (UINT8 *)&SendBuffer);
+    SendBuffer.Header.paramSize = grub_swap_bytes32(SendBufferSize);
+
+    RecvBufferSize = sizeof(RecvBuffer);
+again:
+    Status = grub_tpm2_submit_command(SendBufferSize, (UINT8 *)&SendBuffer, RecvBufferSize, (UINT8 *)&RecvBuffer);
+    if(Status)
+    {
+        goto Done;
+    }
+
+    if(RecvBufferSize < sizeof(TPM2_RESPONSE_HEADER)) 
+    {
+        Status = grub_error(GRUB_ERR_BAD_DEVICE, N_("TPM2 Device response error"));
+    }
+
+    ResponseCode = grub_swap_bytes32(RecvBuffer.Header.responseCode);
+
+    if(ResponseCode == TPM_RC_RETRY)
+    {
+        goto again;
+    }
+
+    switch (ResponseCode) 
+    {
+        case TPM_RC_SUCCESS:
+            break;
+        case TPM_RC_NV_AUTHORIZATION:
+            Status = grub_error(GRUB_ERR_BAD_ARGUMENT, N_("TPM2 Nv Read Bad auth entity "));
+            break;
+        case TPM_RC_NV_LOCKED:
+            Status = grub_error (GRUB_ERR_IO, N_("TPM2 Nv Locked"));
+            break;
+        case TPM_RC_NV_RANGE:
+            Status = grub_error (GRUB_ERR_OUT_OF_RANGE, N_("TPM2 Nv Read out of range"));
+            break;
+        case TPM_RC_NV_UNINITIALIZED:
+            Status = grub_error (GRUB_ERR_IO, N_("TPM2 Nv Uninitialized"));
+            break;
+        case TPM_RC_HANDLE + RC_NV_Read_nvIndex:
+            Status = grub_error (GRUB_ERR_NOT_IMPLEMENTED_YET, "TPM2 Nv Index Not Defined");
+            break;
+        case TPM_RC_VALUE + RC_NV_Read_nvIndex:
+        case TPM_RC_VALUE + RC_NV_Read_authHandle:
+            Status = grub_error(GRUB_ERR_BAD_ARGUMENT, N_("TPM2 Nv Read Wrong Value"));
+            break;
+        case TPM_RC_BAD_AUTH + RC_NV_Read_authHandle + TPM_RC_S:
+            Status = grub_error(GRUB_ERR_ACCESS_DENIED, N_("TPM2 Nv Read Bad Auth"));
+            break;
+        case TPM_RC_AUTH_UNAVAILABLE:
+
+            break;
+        case TPM_RC_AUTH_FAIL + RC_NV_Read_authHandle + TPM_RC_S:
+            Status = grub_error(GRUB_ERR_ACCESS_DENIED, N_("TPM2 Nv Read Auth Fail"));
+            break;
+        case TPM_RC_ATTRIBUTES + RC_NV_Read_authHandle + TPM_RC_S:
+            Status = grub_error(GRUB_ERR_BAD_ARGUMENT, N_("TPM2 Nv Read Wrong Attributes"));
+            break;
+        default:
+            Status = grub_error(GRUB_ERR_BAD_DEVICE, N_("TPM2 Device error"));
+            break;
+    }
+
+    OutData->size = grub_swap_bytes16(RecvBuffer.Data.size);
+    if(OutData->size > MAX_DIGEST_BUFFER)
+    {
+        Status = grub_error(GRUB_ERR_BAD_DEVICE, N_("TPM2 Device response error"));
+        goto Done;
+    }
+
+    grub_memcpy(OutData->buffer, &RecvBuffer.Data.buffer, OutData->size);
+Done:
+    
+    grub_memset(&SendBuffer, 0, sizeof(SendBuffer));
+    grub_memset(&RecvBuffer, 0, sizeof(RecvBuffer));
+
+    return Status;
+}
