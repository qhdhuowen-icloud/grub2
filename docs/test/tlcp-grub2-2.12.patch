+            Buffer += sizeof(UINT16);
+            break;
+#endif
+        default:
+            return grub_error(GRUB_ERR_IO, N_("Parameter invalid"));
+    }
+
+    grub_set_unaligned16(Buffer, grub_swap_bytes16(AuthHash));
+    Buffer += sizeof(UINT16);
+   
+    SendBufferSize = (UINT32) (Buffer - (UINT8 *)&SendBuffer);
+    SendBuffer.Header.paramSize = grub_swap_bytes32(SendBufferSize);
+    
+    RecvBufferSize = sizeof(RecvBuffer);
+    Status = grub_tpm2_submit_command(SendBufferSize, (UINT8 *)&SendBuffer, RecvBufferSize, (UINT8 *)&RecvBuffer);
+    if(Status)
+    {
+        return Status;
+    }
+
+    if(RecvBufferSize < sizeof(TPM2_RESPONSE_HEADER)) 
+    {
+        return grub_error(GRUB_ERR_BAD_DEVICE, N_("TPM2 Device error"));
+    }
+   
+    if(grub_swap_bytes32(RecvBuffer.Header.responseCode) != TPM_RC_SUCCESS)
+    {
+        return grub_error(GRUB_ERR_IO, N_("Command failed"));
+    }
+
+    *SessionHandle = grub_swap_bytes32(RecvBuffer.SessionHandle);
+    NonceTPM->size = grub_swap_bytes32(RecvBuffer.NonceTPM.size);
+    if(NonceTPM->size > sizeof(TPMU_HA))
+    {
+        return grub_error(GRUB_ERR_BAD_DEVICE, N_("TPM2 Device response error"));
+    }
+
+    grub_memcpy(NonceTPM->buffer, &RecvBuffer.NonceTPM.buffer, NonceTPM->size);
+    
+    return 0;
+}
diff --git a/grub-core/kern/efi/tpm2startup.c b/grub-core/kern/efi/tpm2startup.c
new file mode 100644
index 0000000..0be2cea
--- /dev/null
+++ b/grub-core/kern/efi/tpm2startup.c
@@ -0,0 +1,94 @@
+#include <grub/err.h>                                                                                               
+#include <grub/misc.h>                                                                                              
+#include <grub/i18n.h>                                                                                              
+#include <grub/types.h>                                                                                             
+#include <grub/tpm20.h>                                                                                             
+#include <grub/efi/api.h>                                                                                           
+#include <grub/efi/tpm.h>                                                                                           
+#include <grub/efi/tpm2tis.h> 
+#include <grub/efi/tpm2startup.h>
+
+#pragma pack(1)
+
+typedef struct {
+    TPM2_COMMAND_HEADER  Header;
+    TPM_SU               StartupType;
+} TPM2_STARTUP_COMMAND;
+
+typedef struct {
+    TPM2_RESPONSE_HEADER Header;
+} TPM2_STARTUP_RESPONSE;
+
+typedef struct{
+    TPM2_COMMAND_HEADER  Header;
+    TPM_SU               ShutdownType;
+} TPM2_SHUTDOWN_COMMAND;
+
+typedef struct {
+    TPM2_RESPONSE_HEADER Header;
+} TPM2_SHUTDOWN_RESPONSE;
+
+#pragma pack()
+
+
+grub_err_t
+grub_tpm2_startup(TPM_SU      StartupType)
+{
+    grub_efi_status_t          Status;
+    TPM2_STARTUP_COMMAND       Cmd;
+    TPM2_STARTUP_RESPONSE      Res;
+    UINT32                     ResultBufSize;
+    TPM_RC                     ResponseCode;
+
+    Cmd.Header.tag         = grub_swap_bytes16(TPM_ST_NO_SESSIONS);
+    Cmd.Header.paramSize   = grub_swap_bytes32(sizeof(Cmd));
+    Cmd.Header.commandCode = grub_swap_bytes32(TPM_CC_Startup);
+    Cmd.StartupType        = grub_swap_bytes16(StartupType);
+
+    ResultBufSize = sizeof(Res);
+    Status = grub_tpm2_submit_command(sizeof(Cmd), (UINT8 *)&Cmd, ResultBufSize, (UINT8 *)&Res);
+    if(Status)                                                                                                      
+    {                                                                                                               
+        return Status;                                                                                              
+    } 
+
+    ResponseCode = grub_swap_bytes32(Res.Header.responseCode);
+    switch(ResponseCode) 
+    {
+        case TPM_RC_SUCCESS:
+            return 0;
+        case TPM_RC_INITIALIZE:
+            return 0;
+        default:
+            return grub_error (GRUB_ERR_IO, N_("Command Failed"));
+    }
+}
+
+grub_err_t
+grub_tpm2_shutdown(TPM_SU ShutdownType)
+{
+    grub_efi_status_t             Status;
+    TPM2_SHUTDOWN_COMMAND         Cmd;
+    TPM2_SHUTDOWN_RESPONSE        Res;
+    UINT32                        ResultBufSize;
+
+    Cmd.Header.tag            = grub_swap_bytes16(TPM_ST_NO_SESSIONS);
+    Cmd.Header.paramSize      = grub_swap_bytes32(sizeof(Cmd));
+    Cmd.Header.commandCode    = grub_swap_bytes32(TPM_CC_Shutdown);
+    Cmd.ShutdownType          = grub_swap_bytes16(ShutdownType);
+
+    ResultBufSize = sizeof(Res);
+    Status = grub_tpm2_submit_command(sizeof(Cmd), (UINT8 *)&Cmd, ResultBufSize, (UINT8 *)&Res);
+    if(Status)                                                                                                      
+    {                                                                                                               
+        return Status;                                                                                              
+    }
+
+    if (grub_swap_bytes32(Res.Header.responseCode) != TPM_RC_SUCCESS)                                        
+    {                                                                                                               
+        return grub_error(GRUB_ERR_IO, N_("Command failed"));
+    }
+
+    return 0;
+}
+
diff --git a/grub-core/kern/efi/tpm2tis.c b/grub-core/kern/efi/tpm2tis.c
new file mode 100644
index 0000000..5d68536
--- /dev/null
+++ b/grub-core/kern/efi/tpm2tis.c
@@ -0,0 +1,235 @@
+#include <grub/err.h>
+#include <grub/i18n.h>
+#include <grub/efi/api.h>
+#include <grub/efi/efi.h>
+#include <grub/efi/tpm.h>
+#include <grub/efi/tpm2tis.h>
+#include <grub/mm.h>
+#include <grub/tpm.h>
+#include <grub/tpm20.h>
+#include <grub/term.h>
+
+/* grub2-2.12 renamed grub_efi_guid_t to grub_guid_t */
+#define grub_efi_guid_t grub_guid_t
+static grub_guid_t tpm2_guid = EFI_TPM2_GUID;
+
+static grub_efi_boolean_t grub_tpm2_handle_find(grub_efi_handle_t *tpm_handle,
+                                               grub_efi_uint8_t *protocol_version)
+{
+    grub_efi_handle_t         *handles;
+    grub_efi_uintn_t          num_handles;
+
+    handles = grub_efi_locate_handle(GRUB_EFI_BY_PROTOCOL, &tpm2_guid, NULL, &num_handles);
+
+    if(handles && num_handles > 0)
+    {
+        *tpm_handle = handles[0];
+        *protocol_version = 2;
+        grub_free(handles);  //added by wbx 06.22 10:10
+        return 1;
+    }
+    return 0;
+}
+static grub_efi_boolean_t 
+grub_tpm2_present(void)
+{
+    grub_efi_status_t                    status;
+    grub_efi_handle_t                    tpm_handle;
+    grub_uint8_t                         protocol_version;
+    grub_efi_tpm2_protocol_t             *tpm;
+    EFI_TCG2_BOOT_SERVICE_CAPABILITY     caps;
+
+    if (!grub_tpm2_handle_find(&tpm_handle, &protocol_version))
+    {
+        return 0;
+    }
+
+    tpm = grub_efi_open_protocol(tpm_handle, &tpm2_guid, GRUB_EFI_OPEN_PROTOCOL_GET_PROTOCOL);
+
+    caps.Size = (grub_uint8_t)sizeof(caps);
+
+    status = tpm->get_capability(tpm, &caps);
+
+    if(status != GRUB_EFI_SUCCESS || !caps.TPMPresentFlag)
+    {
+        return 0;
+    }
+
+    return 1;
+}
+
+grub_err_t
+grub_tpm2_submit_command(UINT32 inbufsize,
+                          UINT8   *inbuf,
+                          UINT32  outbufsize,
+                          UINT8   *outbuf)
+{
+    grub_efi_status_t             status;
+    grub_efi_tpm2_protocol_t      *tpm;
+    grub_efi_handle_t             tpm_handle;
+    grub_efi_guid_t               guid = EFI_TPM2_GUID;
+    grub_efi_handle_t             *handles;
+    grub_efi_uintn_t              num_handles;
+    
+    if(!grub_tpm2_present())
+    {
+        return grub_error(GRUB_ERR_UNKNOWN_DEVICE, N_("TPM2 unavailable"));
+    }
+
+    handles = grub_efi_locate_handle(GRUB_EFI_BY_PROTOCOL, &guid, NULL,
+                    &num_handles);
+    if(handles && num_handles > 0)
+    {
+        tpm_handle = handles[0];
+    }
+    else
+    {
+        return grub_error(GRUB_ERR_UNKNOWN_DEVICE, N_("TPM2 unavailable"));
+    }
+
+    tpm = grub_efi_open_protocol(tpm_handle, &guid, 
+                GRUB_EFI_OPEN_PROTOCOL_GET_PROTOCOL);
+#if 0
+    grub_uint8_t               i;
+    grub_printf("-------------------------------grub_tpm2_submit_command------------------------------\n");
+    grub_printf("inbufsize:0x%.2x\n", inbufsize);
+    for(i = 0; i < inbufsize; i++)
+    {
+        if(i != 0 && i % 16 == 0)
+        {
+            grub_printf("\n");
+        }
+        grub_printf("0x%.2x ", *(inbuf + i));
+    }
+    grub_printf("\n");
+#endif
+    status = tpm->submit_command(tpm,
+                                  inbufsize, inbuf,
+                                  outbufsize, outbuf);
+#if 0
+    grub_printf("outbufsize:0x%.2x\n", outbufsize);
+    grub_printf("-------------------------------grub_tpm2_submit_command------------------------------\n");
+    for(i = 0; i < 32; i++)
+    {   
+        if(i != 0 && i % 16 == 0)
+        {   
+            grub_printf("\n");
+        }
+        grub_printf("0x%.2x ", *(outbuf + i));
+    }
+    grub_printf("\n");
+#endif
+    if(handles)   //added by wbx 06.22 10:05
+        grub_free(handles); //added by wbx 06.22 10:05
+    switch(status)
+    {
+        case GRUB_EFI_SUCCESS:
+            return 0;
+        case GRUB_EFI_DEVICE_ERROR:
+            return grub_error(GRUB_ERR_IO, N_("Command failed"));
+        case GRUB_EFI_INVALID_PARAMETER:
+            return grub_error(GRUB_ERR_BAD_ARGUMENT, N_("Invalid parameter"));
+        case GRUB_EFI_BUFFER_TOO_SMALL:
+            return grub_error(GRUB_ERR_BAD_ARGUMENT, N_("Output buffer too small"));
+        case GRUB_EFI_NOT_FOUND:
+            return grub_error(GRUB_ERR_UNKNOWN_DEVICE, N_("TPM unavailable"));
+        default:
+            return grub_error(GRUB_ERR_UNKNOWN_DEVICE, N_("Unknown TPM error"));
+    }      
+}
+
+
+grub_uint32_t
+grub_tpm2_copy_auth_session_command(TPMS_AUTH_COMMAND           *AuthSessionIn,
+                                    UINT8                       *AuthSessionOut)
+{
+    UINT8          *Buffer;
+
+    Buffer = (UINT8 *)AuthSessionOut;
+    if(AuthSessionIn != NULL)
+    {
+        //session handle
+        grub_set_unaligned32(Buffer, grub_swap_bytes32(AuthSessionIn->sessionHandle));
+        Buffer += sizeof(UINT32);
+
+        //nonce
+        grub_set_unaligned16(Buffer, grub_swap_bytes16(AuthSessionIn->nonce.size));
+        Buffer += sizeof(UINT16);
+
+        grub_memcpy(Buffer, AuthSessionIn->nonce.buffer, AuthSessionIn->nonce.size);
+        Buffer += AuthSessionIn->nonce.size;
+
+        //session attributes
+        *(UINT8 *)Buffer = *(UINT8 *)&AuthSessionIn->sessionAttributes;
+        Buffer++;
+
+        // hmac
+        grub_set_unaligned16(Buffer, grub_swap_bytes16 (AuthSessionIn->hmac.size));
+        Buffer += sizeof(UINT16);
+
+        grub_memcpy(Buffer, AuthSessionIn->hmac.buffer, AuthSessionIn->hmac.size);
+        Buffer += AuthSessionIn->hmac.size;
+    }
+    else
+    {
+        // session handle
+        grub_set_unaligned32(Buffer, grub_swap_bytes32(TPM_RS_PW));
+        Buffer += sizeof(UINT32);
+
+        // nonce
+        grub_set_unaligned16(Buffer, grub_swap_bytes16(0));
+        Buffer += sizeof(UINT16);
+
+        // session attributes
+        *(UINT8 *)Buffer = 0x00;
+        Buffer++;
+
+        // hmac
+        grub_set_unaligned16(Buffer, grub_swap_bytes16(0));
+        Buffer += sizeof(UINT16);
+    }
+    return (grub_uint32_t)((UINT8 *)Buffer - (UINT8 *)AuthSessionOut);
+}
+
+grub_uint32_t
+grub_tpm2_copy_auth_session_response(UINT8                *AuthSessionIn,
+                                     TPMS_AUTH_RESPONSE   *AuthSessionOut)
+{
+    UINT8               *Buffer;
+
+    if( AuthSessionOut == NULL )
+    {
+        return 0;
+    }
+
+    Buffer = (UINT8 *)AuthSessionIn;
+
+    // nonce
+    AuthSessionOut->nonce.size = grub_swap_bytes16(grub_get_unaligned16(Buffer));
+    Buffer += sizeof(UINT16);
+    if(AuthSessionOut->nonce.size > sizeof(TPMU_HA))
+    {
+        return 0;
+    }
+
+    grub_memcpy(AuthSessionOut->nonce.buffer, Buffer, AuthSessionOut->nonce.size);
+    Buffer += AuthSessionOut->nonce.size;
+
+    // session attributes
+    *(UINT8 *)&AuthSessionOut->sessionAttributes = *(UINT8 *)Buffer;
+    Buffer++;
+
+    // hmac
+    AuthSessionOut->hmac.size = grub_swap_bytes16(grub_get_unaligned16(Buffer));
+    Buffer += sizeof(UINT16);
+    if(AuthSessionOut->hmac.size > sizeof(TPMU_HA))
+    {
+        return 0;
+    }
+
+    grub_memcpy(AuthSessionOut->hmac.buffer, Buffer, AuthSessionOut->hmac.size);
+    Buffer += AuthSessionOut->hmac.size;
+
+    return (grub_uint32_t)((UINT8 *)Buffer - (UINT8 *)AuthSessionIn);
+}
+ 
diff --git a/grub-core/kern/tlcp.c b/grub-core/kern/tlcp.c
new file mode 100644
index 0000000..cacfac2
--- /dev/null
+++ b/grub-core/kern/tlcp.c
@@ -0,0 +1,655 @@
+/*
+ *  GRUB  --  GRand Unified Bootloader
+ *  iTrustMidware TLCP trusted boot core for grub2-2.12
+ *
+ *  This file implements the public TLCP API called from commands/boot.c:
+ *    grub_tpm_policy_state()        — determine policy type via TPM
+ *    grub_file_policy_state()       — determine policy type via file
+ *    grub_tpm_integrity_validation()  — validate integrity via TPM Unseal
+ *    grub_file_integrity_validation() — validate integrity via passphrase
+ *    grub_measure_configured_files()  — extend PCR with config file hash
+ *
+ *  State file format (hardware_state.bin / software_state.bin):
+ *    [0..31]  SHA256(decryption_key)          — integrity check
+ *    [32..]   AES-128-CBC(magic_string, key)  — plaintext after decrypt
+ *
+ *  Magic strings (verified after decryption):
+ *    hardware: "INSPUR__HARDWARE"
+ *    software: "INSPUR__SOFTWARE"
+ */
+
+#include <grub/err.h>
+#include <grub/env.h>
+#include <grub/time.h>
+#include <grub/i18n.h>
+#include <grub/misc.h>
+#include <grub/mm.h>
+#include <grub/tlcp.h>
+#include <grub/term.h>
+#include <grub/tlcp_sha256.h>
+#include <grub/tlcp_aes.h>
+#include <grub/file.h>
+
+/* EFI-specific PCR measurement helper (kern/efi/tlcp.c) */
+#if defined (GRUB_MACHINE_EFI)
+grub_err_t grub_tlcp_efi_measure (unsigned char *buf, grub_size_t size,
+                                   grub_uint8_t pcr, const char *description);
+#endif
+
+#define DEFAULT_KEY_LEN     128
+#define HARDINFO            "INSPUR__HARDWARE"
+#define SOFTINFO            "INSPUR__SOFTWARE"
+#define SHA256_DIGEST_LEN   32
+#define AES_BLOCK_SIZE      16
+
+/* Configuration file measured into PCR 12 */
+#define MEASUREMENT_CONFIG_FILE  "/host_st_configure.xml"
+
+/* -------------------------------------------------------------------------
+ * Terminal helpers
+ * ---------------------------------------------------------------------- */
+
+static void
+grub_tlcp_cls (void)
+{
+    struct grub_term_output *term;
+    FOR_ACTIVE_TERM_OUTPUTS (term)
+    {
+        if ((term->flags & GRUB_TERM_DUMB) || grub_env_get ("debug"))
+            grub_term_refresh (term);
+        else
+            term->cls (term);
+    }
+}
+
+static int
+grub_tlcp_password_get (char buf[], unsigned buf_size)
+{
+    unsigned cur_len = 0;
+    int key;
+
+    while (1)
+    {
+        key = grub_getkey ();
+        if (key == '\n' || key == '\r')
+            break;
+        if (key == GRUB_TERM_ESC)
+        {
+            cur_len = 0;
+            break;
+        }
+        if (key == '\b' && cur_len)
+        {
+            cur_len--;
+            continue;
+        }
+        if (!grub_isprint (key))
+            continue;
+        if (cur_len + 2 < buf_size)
+            buf[cur_len++] = key;
+    }
+
+    grub_memset (buf + cur_len, 0, buf_size - cur_len);
+    grub_xputs ("\n");
+    grub_refresh ();
+    return (key != GRUB_TERM_ESC);
+}
+
+/* -------------------------------------------------------------------------
+ * Policy state
+ * ---------------------------------------------------------------------- */
+
+/*
+ * grub_tpm_policy_state - determine policy state, preferring TPM NV.
+ *
+ * Returns a bitmask:
+ *   POLICY_STATE_NONE         — no policy deployed
+ *   POLICY_STATE_TPM_CHECK | POLICY_STATE_AUDIT       — TPM + audit
+ *   POLICY_STATE_TPM_CHECK | POLICY_STATE_SUPERVISORY — TPM + supervisory
+ *   POLICY_STATE_SUPERVISORY  — file-based supervisory (TPM unavailable)
+ */
+grub_err_t
+grub_tpm_policy_state (void)
+{
+    int policy_state_tpm  = TSS2_APP_RC_POLICY_NOT_EXIST;
+    int policy_state_file = TSS2_APP_RC_POLICY_NOT_EXIST;
+
+    policy_state_tpm = check_tpm_policy_state ();
+    if (policy_state_tpm == TSS2_APP_RC_AUDIT_POLICY_EXIST)
+        return POLICY_STATE_TPM_CHECK | POLICY_STATE_AUDIT;
+    if (policy_state_tpm == TSS2_APP_RC_SUPERVISORY_POLICY_EXIST)
+        return POLICY_STATE_TPM_CHECK | POLICY_STATE_SUPERVISORY;
+
+    /* TPM check failed — fall back to policy file */
+    policy_state_file = check_file_policy_state ();
+    if (policy_state_file == TSS2_APP_RC_AUDIT_POLICY_EXIST ||
+        policy_state_file == TSS2_APP_RC_SUPERVISORY_POLICY_EXIST)
+        return POLICY_STATE_SUPERVISORY;
+
+    if (policy_state_file == TSS2_APP_RC_POLICY_NOT_EXIST &&
+        policy_state_tpm  == TSS2_APP_RC_POLICY_NOT_EXIST)
+        return POLICY_STATE_NONE;
+
+    return POLICY_STATE_SUPERVISORY;
+}
+
+/*
+ * grub_file_policy_state - determine policy state using only /boot/policy.bin.
+ * Used when the TPM is absent.
+ */
+grub_err_t
+grub_file_policy_state (void)
+{
+    int file_state = check_file_policy_state ();
+
+    if (file_state == TSS2_APP_RC_AUDIT_POLICY_EXIST ||
+        file_state == TSS2_APP_RC_SUPERVISORY_POLICY_EXIST)
+        return POLICY_STATE_SUPERVISORY;
+
+    if (file_state == TSS2_APP_RC_POLICY_NOT_EXIST)
+        return POLICY_STATE_NONE;
+
+    return POLICY_STATE_SUPERVISORY;
+}
+
+/* -------------------------------------------------------------------------
+ * Key derivation from passphrase
+ * ---------------------------------------------------------------------- */
+
+static char
+hex_char_to_int (char c)
+{
+    if (c >= '0' && c <= '9') return c - '0';
+    if (c >= 'A' && c <= 'F') return c - 'A' + 10;
+    if (c >= 'a' && c <= 'f') return c - 'a' + 10;
+    return (char)0xFF;
+}
+
+static int
+hex_string_to_bytes (const char *in, int size, unsigned char *out)
+{
+    int i;
+    for (i = 0; i < size; i += 2)
+    {
+        char hi = hex_char_to_int (in[i]);
+        char lo = hex_char_to_int (in[i + 1]);
+        if ((unsigned char)hi == 0xFF || (unsigned char)lo == 0xFF)
+            return -1;
+        out[i / 2] = (unsigned char)((hi << 4) | lo);
+    }
+    return size / 2;
+}
+
+static int
+create_key (unsigned char *passphrase, int passphrase_len,
+            unsigned char **key, int *key_len)
+{
+    if (passphrase_len <= 0 || !passphrase)
+    {
+        *key = NULL;
+        *key_len = 0;
+        return -1;
+    }
+    *key = grub_zalloc (DEFAULT_KEY_LEN);
+    if (!*key)
+        return -1;
+    grub_memcpy (*key, passphrase, passphrase_len);
+    *key_len = DEFAULT_KEY_LEN;
+    return 0;
+}
+
+static int
+convert_passphrase_to_key (char *passphrase, int passphrase_len,
+                            unsigned char **key, int *key_len)
+{
+    unsigned char passphrase_byte[32] = { 0 };
+    int result;
+
+    if (passphrase_len == 0 || passphrase_len % 2 != 0)
+        return -1;
+
+    result = hex_string_to_bytes (passphrase, passphrase_len, passphrase_byte);
+    if (result < 0)
+        return -1;
+
+    return create_key (passphrase_byte, passphrase_len / 2, key, key_len);
+}
+
+/* -------------------------------------------------------------------------
+ * SHA256 wrapper
+ * ---------------------------------------------------------------------- */
+
+static void
+tlcp_sha256 (unsigned char *in, int in_len,
+             unsigned char *out, int *out_len)
+{
+    unsigned int  data_hash[8] = { 0 };
+    sha256_context context;
+    int           i;
+
+    if (!in || in_len <= 0)
+        return;
+
+    sha256_init (&context);
+    sha256_update (&context, in, (unsigned int)in_len);
+    sha256_finalize (&context, data_hash);
+
+    /* Convert from little-endian words to byte array */
+    for (i = 0; i < 8; i++)
+    {
+        out[4*i + 0] = (data_hash[i] >> 24) & 0xff;
+        out[4*i + 1] = (data_hash[i] >> 16) & 0xff;
+        out[4*i + 2] = (data_hash[i] >>  8) & 0xff;
+        out[4*i + 3] =  data_hash[i]        & 0xff;
+    }
+    *out_len = SHA256_DIGEST_LEN;
+}
+
+/* -------------------------------------------------------------------------
+ * AES-128-CBC decryption wrapper
+ * ---------------------------------------------------------------------- */
+
+static void
+tlcp_aes_decrypt (unsigned char *key, int key_len __attribute__((unused)),
+                  unsigned char *msg, int msg_len,
+                  unsigned char *out)
+{
+    AES_CTX         ctx;
+    unsigned char   iv[AES_BLOCK_SIZE] = { 0 };
+
+    AES_set_key (&ctx, key, iv, AES_MODE_128);
+    AES_convert_key (&ctx);
+    AES_cbc_decrypt (&ctx, msg, out, msg_len);
+}
+
+/* -------------------------------------------------------------------------
+ * State file validation
+ *
+ * Format: [SHA256(key) | AES-128-CBC(magic_string, key)]
+ * ---------------------------------------------------------------------- */
+
+/*
+ * validate_key_against_state - decrypt state file content with the given key
+ * and verify the magic string.
+ *
+ * Returns 0 on success (integrity OK), -1 on failure.
+ */
+static int
+validate_key_against_state (unsigned char *key, int key_len,
+                             unsigned char *buf, int buf_len,
+                             const char *magic)
+{
+    unsigned char key_hash[SHA256_DIGEST_LEN] = { 0 };
+    unsigned char out[64] = { 0 };
+    int           hash_len = 0;
+
+    if (buf_len < SHA256_DIGEST_LEN + AES_BLOCK_SIZE)
+        return -1;
+
+    /* Compute SHA256(key) and compare with first 32 bytes of state file */
+    tlcp_sha256 (key, key_len, key_hash, &hash_len);
+    if (grub_memcmp (key_hash, buf, SHA256_DIGEST_LEN) != 0)
+        return -1;
+
+    /* Decrypt the remainder and check the magic string */
+    tlcp_aes_decrypt (key, key_len,
+                      buf + SHA256_DIGEST_LEN,
+                      buf_len - SHA256_DIGEST_LEN,
+                      out);
+
+    if (grub_memcmp (magic, out, grub_strlen (magic)) != 0)
+        return -1;
+
+    return 0;
+}
+
+/* -------------------------------------------------------------------------
+ * TPM-based integrity validation (using TPM2 Unseal)
+ * ---------------------------------------------------------------------- */
+
+static grub_err_t
+tpm_hardware_integrity_validation (unsigned char *buf, int buf_len)
+{
+    unsigned char *key     = NULL;
+    int            key_len = 0;
+    grub_err_t     result;
+
+    result = get_hardware_dec_key (&key, &key_len);
+    if (result)
+    {
+        grub_printf (N_("Error: hardware PCR state mismatch (TPM Unseal failed).\n"));
+        result = TSS2_APP_RC_BAD_TRUST_STATE;
+        goto end;
+    }
+
+    if (validate_key_against_state (key, key_len, buf, buf_len, HARDINFO) != 0)
+    {
+        grub_printf (N_("Error: hardware state file validation failed.\n"));
+        result = TSS2_APP_RC_BAD_TRUST_STATE;
+        goto end;
+    }
+
+end:
+    if (key)
+    {
+        grub_free (key);
+        key = NULL;
+    }
+    return result;
+}
+
+static grub_err_t
+tpm_software_integrity_validation (unsigned char *buf, int buf_len)
+{
+    unsigned char *key     = NULL;
+    int            key_len = 0;
+    grub_err_t     result;
+
+    result = get_software_dec_key (&key, &key_len);
+    if (result)
+    {
+        grub_printf (N_("Error: software PCR state mismatch (TPM Unseal failed).\n"));
+        result = TSS2_APP_RC_BAD_TRUST_STATE;
+        goto end;
+    }
+
+    if (validate_key_against_state (key, key_len, buf, buf_len, SOFTINFO) != 0)
+    {
+        grub_printf (N_("Error: software state file validation failed.\n"));
+        result = TSS2_APP_RC_BAD_TRUST_STATE;
+        goto end;
+    }
+
+end:
+    if (key)
+    {
+        grub_free (key);
+        key = NULL;
+    }
+    return result;
+}
+
+/*
+ * grub_tpm_integrity_validation - check hardware and software integrity via TPM.
+ *
+ * @halt: if non-zero, prompt for manual passphrase when TPM check fails.
+ */
+grub_err_t
+grub_tpm_integrity_validation (int halt)
+{
+    unsigned char *hard_buf = NULL, *soft_buf = NULL;
+    int            hard_len = 0,     soft_len = 0;
+    grub_err_t     hard_integrity, soft_integrity;
+    grub_err_t     result;
+    grub_uint64_t  endtime;
+
+    result = get_hardware_enc_content (&hard_buf, &hard_len);
+    if (result)
+    {
+        grub_printf (N_("Error: cannot read hardware state file.\n"));
+        goto end;
+    }
+
+    result = get_software_enc_content (&soft_buf, &soft_len);
+    if (result)
+    {
+        grub_printf (N_("Error: cannot read software state file.\n"));
+        goto end;
+    }
+
+    /* --- Hardware check --- */
+    hard_integrity = tpm_hardware_integrity_validation (hard_buf, hard_len);
+    if (hard_integrity)
+    {
+        grub_printf (N_("*********************************************\n"));
+        grub_printf (N_("*    Platform Integrity Has been Broken!    *\n"));
+        grub_printf (N_("*********************************************\n"));
+    }
+    else
+    {
+        grub_printf (N_("---------------------------------------------\n"));
+        grub_printf (N_("|       Platform Integrity is Well!         |\n"));
+        grub_printf (N_("---------------------------------------------\n"));
+    }
+
+    endtime = grub_get_time_ms () + 500;
+    while (grub_get_time_ms () < endtime);
+
+    /* --- Software check --- */
+    soft_integrity = tpm_software_integrity_validation (soft_buf, soft_len);
+    if (soft_integrity)
+    {
+        grub_printf (N_("*********************************************\n"));
+        grub_printf (N_("*  Host OS Kernel&Initrd Has been Broken!   *\n"));
+        grub_printf (N_("*********************************************\n"));
+    }
+    else
+    {
+        grub_printf (N_("---------------------------------------------\n"));
+        grub_printf (N_("|     Host OS Kernel&Initrd are Well!       |\n"));
+        grub_printf (N_("---------------------------------------------\n"));
+    }
+
+    endtime = grub_get_time_ms () + 500;
+    while (grub_get_time_ms () < endtime);
+
+    /*
+     * If any integrity check failed and halt is requested, invoke the
+     * passphrase fallback exactly once.  Calling it separately inside each
+     * check would prompt the user twice when both hardware and software fail.
+     */
+    if ((hard_integrity || soft_integrity) && halt)
+        grub_file_integrity_validation (1);
+
+end:
+    if (hard_buf) grub_free (hard_buf);
+    if (soft_buf) grub_free (soft_buf);
+    return GRUB_ERR_NONE;
+}
+
+/* -------------------------------------------------------------------------
+ * Passphrase-based fallback validation
+ * ---------------------------------------------------------------------- */
+
+/*
+ * Prompt in an infinite loop until the user enters the correct passphrase
+ * for the hardware state file.
+ */
+static void
+file_hardware_integrity_validation (unsigned char *buf, int buf_len)
+{
+    char           passphrase[32];
+    unsigned char *key     = NULL;
+    int            key_len = 0;
+
+    while (1)
+    {
+        if (key) { grub_free (key); key = NULL; key_len = 0; }
+        grub_memset (passphrase, 0, sizeof (passphrase));
+
+        grub_printf (N_("Enter hardware passphrase: "));
+        if (!grub_tlcp_password_get (passphrase, sizeof (passphrase)) ||
+            grub_strlen (passphrase) == 0)
+        {
+            grub_tlcp_cls ();
+            grub_printf (N_("Error: hardware passphrase not supplied!\n"));
+            continue;
+        }
+
+        if (convert_passphrase_to_key (passphrase, grub_strlen (passphrase),
+                                       &key, &key_len) != 0)
+        {
+            grub_tlcp_cls ();
+            grub_printf (N_("Error: invalid hardware passphrase format!\n"));
+            continue;
+        }
+
+        if (validate_key_against_state (key, key_len, buf, buf_len,
+                                        HARDINFO) != 0)
+        {
+            grub_tlcp_cls ();
+            grub_printf (N_("Error: hardware passphrase incorrect!\n"));
+            continue;
+        }
+
+        grub_printf (N_("Hardware passphrase accepted.\n"));
+        break;
+    }
+    if (key) grub_free (key);
+}
+
+/*
+ * Prompt in an infinite loop until the user enters the correct passphrase
+ * for the software state file.
+ */
+static void
+file_software_integrity_validation (unsigned char *buf, int buf_len)
+{
+    char           passphrase[32];
+    unsigned char *key     = NULL;
+    int            key_len = 0;
+
+    while (1)
+    {
+        if (key) { grub_free (key); key = NULL; key_len = 0; }
+        grub_memset (passphrase, 0, sizeof (passphrase));
+
+        grub_printf (N_("Enter software passphrase: "));
+        if (!grub_tlcp_password_get (passphrase, sizeof (passphrase)) ||
+            grub_strlen (passphrase) == 0)
+        {
+            grub_tlcp_cls ();
+            grub_printf (N_("Error: software passphrase not supplied!\n"));
+            continue;
+        }
+
+        if (convert_passphrase_to_key (passphrase, grub_strlen (passphrase),
+                                       &key, &key_len) != 0)
+        {
+            grub_tlcp_cls ();
+            grub_printf (N_("Error: invalid software passphrase format!\n"));
+            continue;
+        }
+
+        if (validate_key_against_state (key, key_len, buf, buf_len,
+                                        SOFTINFO) != 0)
+        {
+            grub_tlcp_cls ();
+            grub_printf (N_("Error: software passphrase incorrect!\n"));
+            continue;
+        }
+
+        grub_printf (N_("Software passphrase accepted.\n"));
+        break;
+    }
+    if (key) grub_free (key);
+}
+
+/*
+ * grub_file_integrity_validation - passphrase-based integrity check.
+ *
+ * Used when: (a) no TPM present, (b) supervisory policy active,
+ * or (c) TPM check failed and halt=1.
+ *
+ * Always prompts for both hardware and software passphrases.
+ */
+grub_err_t
+grub_file_integrity_validation (int halt __attribute__((unused)))
+{
+    unsigned char *hard_buf = NULL, *soft_buf = NULL;
+    int            hard_len = 0,     soft_len = 0;
+    grub_err_t     result;
+    grub_uint64_t  endtime;
+
+    result = get_hardware_enc_content (&hard_buf, &hard_len);
+    if (result)
+    {
+        grub_printf (N_("Error: cannot read hardware state file.\n"));
+        goto end;
+    }
+
+    result = get_software_enc_content (&soft_buf, &soft_len);
+    if (result)
+    {
+        grub_printf (N_("Error: cannot read software state file.\n"));
+        goto end;
+    }
+
+    grub_printf (N_("*********************************************\n"));
+    grub_printf (N_("*    Platform Integrity Has been Broken!    *\n"));
+    grub_printf (N_("*********************************************\n"));
+    file_hardware_integrity_validation (hard_buf, hard_len);
+
+    endtime = grub_get_time_ms () + 500;
+    while (grub_get_time_ms () < endtime);
+
+    grub_printf (N_("*********************************************\n"));
+    grub_printf (N_("*  Host OS Kernel&Initrd Has been Broken!   *\n"));
+    grub_printf (N_("*********************************************\n"));
+    file_software_integrity_validation (soft_buf, soft_len);
+
+    endtime = grub_get_time_ms () + 500;
+    while (grub_get_time_ms () < endtime);
+
+end:
+    if (hard_buf) grub_free (hard_buf);
+    if (soft_buf) grub_free (soft_buf);
+    return GRUB_ERR_NONE;
+}
+
+/* -------------------------------------------------------------------------
+ * PCR measurement of the configuration file
+ * ---------------------------------------------------------------------- */
+
+/*
+ * grub_measure_configured_files - read /boot/host_st_configure.xml and
+ * extend its content into PCR 12.
+ *
+ * This ties the GRUB configuration to the PCR state evaluated during
+ * the software key Unseal.  If the file is absent, the function is a no-op.
+ */
+grub_err_t
+grub_measure_configured_files (void)
+{
+    grub_err_t  result = GRUB_ERR_NONE;
+    grub_file_t file   = 0;
+    char       *buf    = 0;
+    grub_size_t len    = 0;
+
+    file = grub_file_open (MEASUREMENT_CONFIG_FILE, GRUB_FILE_TYPE_CAT);
+    if (!file || !file->size)
+    {
+        /* Configuration file absent — nothing to measure */
+        if (grub_errno != GRUB_ERR_NONE)
+            grub_errno = GRUB_ERR_NONE;
+        goto end;
+    }
+
+    len = (grub_size_t)file->size;
+    buf = grub_malloc (len + 1);
+    if (!buf)
+    {
+        result = GRUB_ERR_OUT_OF_MEMORY;
+        goto end;
+    }
+
+    if ((grub_size_t)grub_file_read (file, buf, len) != len)
+        goto end;
+
+    /*
+     * Extend the raw file content into PCR 12 (TLCP_APPLICATION_PCR).
+     * grub_tlcp_efi_measure() is implemented in kern/efi/tlcp.c using the
+     * EFI TCG2 protocol directly (avoids depending on the tpm module).
+     * On non-EFI platforms this is a no-op.
+     */
+#if defined (GRUB_MACHINE_EFI)
+    grub_tlcp_efi_measure ((unsigned char *)buf, (grub_size_t)len,
+                           TLCP_APPLICATION_PCR,
+                           "iTrustMidware:host_st_configure.xml");
+#endif
+
+end:
+    if (buf)  grub_free (buf);
+    if (file) grub_file_close (file);
+    return result;
+}
