diff --git a/grub-core/commands/boot.c b/grub-core/commands/boot.c
index 6151478..2cec486 100644
--- a/grub-core/commands/boot.c
+++ b/grub-core/commands/boot.c
@@ -24,6 +24,8 @@
 #include <grub/kernel.h>
 #include <grub/mm.h>
 #include <grub/i18n.h>
+#include <grub/tpm.h>
+#include <grub/tlcp.h>
 
 GRUB_MOD_LICENSE ("GPLv3+");
 
@@ -225,6 +227,53 @@ grub_cmd_boot (struct grub_command *cmd __attribute__ ((unused)),
 		    int argc __attribute__ ((unused)),
 		    char *argv[] __attribute__ ((unused)))
 {
+  int        key = 0;
+  int        policy_state = -1;
+
+  (void)key;
+  grub_measure_configured_files();
+
+  /*
+   * grub_tpm_present() is only available on EFI and powerpc_ieee1275.
+   * On other platforms (e.g. i386-pc) skip straight to file-based policy.
+   */
+#if defined(GRUB_MACHINE_EFI) || defined(GRUB_MACHINE_IEEE1275)
+  if(grub_tpm_present())
+    {
+      policy_state = grub_tpm_policy_state();
+      if(policy_state == POLICY_STATE_NONE)
+      {
+          goto trust_end;
+      }
+      else if(policy_state & POLICY_STATE_TPM_MASK)
+      {
+        if((policy_state & POLICY_STATE_CHEKC_MASK) == POLICY_STATE_AUDIT)
+        {
+          grub_tpm_integrity_validation(0);
+        }
+        else
+        {
+          grub_tpm_integrity_validation(1);
+        }
+      }
+      else
+      {
+        if(((policy_state & POLICY_STATE_CHEKC_MASK) == POLICY_STATE_AUDIT) || ((policy_state & POLICY_STATE_CHEKC_MASK) == POLICY_STATE_SUPERVISORY))
+        {
+          grub_file_integrity_validation(1);
+        }
+      }
+    }
+    else
+#endif /* GRUB_MACHINE_EFI || GRUB_MACHINE_IEEE1275 */
+    {
+      policy_state = grub_file_policy_state();
+      if(((policy_state & POLICY_STATE_CHEKC_MASK) == POLICY_STATE_AUDIT) || ((policy_state & POLICY_STATE_CHEKC_MASK) == POLICY_STATE_SUPERVISORY))
+      {
+        grub_file_integrity_validation(1);
+      }
+    }
+trust_end:
   return grub_loader_boot ();
 }
 
diff --git a/grub-core/kern/efi/tlcp.c b/grub-core/kern/efi/tlcp.c
new file mode 100644
index 0000000..63337cd
--- /dev/null
+++ b/grub-core/kern/efi/tlcp.c
@@ -0,0 +1,744 @@
+/*
+ *  GRUB  --  GRand Unified Bootloader
+ *  iTrustMidware TLCP EFI implementation for grub2-2.12
+ *
+ *  Implements TPM2-based policy state checking and key unsealing.
+ *  All TPM2 command sequences follow the TCG TPM2.0 Library Specification.
+ *
+ *  Policy binding:
+ *    Hardware key (0x81010101): PCRs 0,1,2,3,6,7 (BIOS, device, secure boot config)
+ *    Software key (0x81010100): PCRs 8,9,12     (kernel, initrd, GRUB modules)
+ *    NV index      (0x01800100): policy state metadata
+ */
+
+#include <grub/efi/efi.h>
+#include <grub/efi/tpm.h>
+#include <grub/efi/tpm2tis.h>
+#include <grub/efi/tpm2nvstorage.h>
+#include <grub/efi/tpm2getcapability.h>
+#include <grub/efi/tpm2session.h>
+#include <grub/efi/tpm2object.h>
+#include <grub/efi/tpm2context.h>
+#include <grub/efi/tpm2startup.h>
+#include <grub/efi/tpm2enhancedauthorization.h>
+#include <grub/tpm20.h>
+#include <grub/tpm.h>
+#include <grub/tlcp.h>
+#include <grub/file.h>
+#include <grub/mm.h>
+#include <grub/misc.h>
+
+/* TPM persistent handle for software policy key (PCRs 8,9,12) */
+#define SOFTWARE_POLICY_KEY   0x81010100
+/* TPM persistent handle for hardware policy key (PCRs 0,1,2,3,6,7) */
+#define HARDWARE_POLICY_KEY   0x81010101
+/* NV index storing the policy state (1=audit, 2=supervisory) */
+#define POLICY_STATE_NV       0x01800100
+
+#define HARDWAREFILE  "/hardware_state.bin"
+#define SOFTWAREFILE  "/software_state.bin"
+#define POLICYFILE    "/policy.bin"
+
+/* PCR selection helper macros */
+#define SET_PCR_SELECT_BIT(sel, pcr) \
+    ((sel).pcrSelect[((pcr)/8)] |= (1 << ((pcr) % 8)))
+#define CLEAR_PCR_SELECT_BITS(sel) \
+    do { (sel).pcrSelect[0] = 0; (sel).pcrSelect[1] = 0; \
+         (sel).pcrSelect[2] = 0; } while (0)
+
+enum POLICY_STATE_CODE {
+    POLICY_NOT_EXIST       = 0,
+    AUDIT_POLICY_EXIST     = 1,
+    SUPERVISORY_POLICY_EXIST = 2,
+};
+
+static unsigned int
+change_endian_dword (unsigned int p)
+{
+    return (((p & 0x000000FF) << 24) |
+            ((p & 0x0000FF00) <<  8) |
+            ((p & 0x00FF0000) >>  8) |
+            ((p & 0xFF000000) >> 24));
+}
+
+static void
+unmarshal_uint32 (unsigned char *buffer, unsigned int *value)
+{
+    *value = change_endian_dword (grub_get_unaligned32 (buffer));
+}
+
+/* -------------------------------------------------------------------------
+ * Policy state detection
+ * ---------------------------------------------------------------------- */
+
+/*
+ * check_tpm_policy_state - query TPM NV and persistent handles to determine
+ * whether a TLCP policy has been deployed.
+ *
+ * Returns:
+ *   TSS2_APP_RC_AUDIT_POLICY_EXIST       — audit policy active
+ *   TSS2_APP_RC_SUPERVISORY_POLICY_EXIST — supervisory policy active
+ *   TSS2_APP_RC_POLICY_NOT_EXIST         — no policy
+ *   TSS2_APP_RC_BAD_POLICY_STATE         — inconsistent state
+ */
+grub_err_t
+check_tpm_policy_state (void)
+{
+    int                  result = TSS2_APP_RC_POLICY_NOT_EXIST;
+    grub_err_t           tpm_rc;
+    int                  soft_key_exist = 0;
+    int                  hard_key_exist = 0;
+    int                  nv_exist = 0;
+    TPMI_YES_NO          more;
+    TPMS_CAPABILITY_DATA capability_data;
+    TPMS_AUTH_COMMAND    session;
+    unsigned int         count;
+    TPM2B_MAX_BUFFER     out;
+    unsigned int         policy_state = 0;
+
+    /* 0. Ensure TPM is started */
+    grub_tpm2_startup (TPM_SU_CLEAR);
+
+    /* 1. Check owner auth is set (indicator that policy was deployed) */
+    tpm_rc = grub_tpm2_get_capability (TPM_CAP_TPM_PROPERTIES,
+                                       TPM_PT_PERMANENT, 1,
+                                       &more, &capability_data);
+    if (tpm_rc)
+    {
+        result = TSS2_APP_RC_BAD_POLICY_STATE;
+        goto end;
+    }
+    if (!(capability_data.data.tpmProperties.tpmProperty[0].value &
+          0x00000001 /* TPMA_PERMANENT_OWNERAUTHSET */))
+    {
+        result = TSS2_APP_RC_POLICY_NOT_EXIST;
+        goto end;
+    }
+
+    /* 2. Check software policy key handle exists */
+    grub_memset (&capability_data, 0, sizeof (TPMS_CAPABILITY_DATA));
+    tpm_rc = grub_tpm2_get_capability (TPM_CAP_HANDLES, SOFTWARE_POLICY_KEY,
+                                       MAX_CAP_HANDLES, &more, &capability_data);
+    if (tpm_rc)
+    {
+        result = TSS2_APP_RC_BAD_POLICY_STATE;
+        goto end;
+    }
+    for (count = 0; count < capability_data.data.handles.count; count++)
+    {
+        if (capability_data.data.handles.handle[count] == (UINT32)SOFTWARE_POLICY_KEY)
+        {
+            soft_key_exist = 1;
+            break;
+        }
+    }
+    if (!soft_key_exist)
+    {
+        result = TSS2_APP_RC_BAD_POLICY_STATE;
+        goto end;
+    }
+
+    /* 3. Check hardware policy key handle exists */
+    grub_memset (&capability_data, 0, sizeof (TPMS_CAPABILITY_DATA));
+    tpm_rc = grub_tpm2_get_capability (TPM_CAP_HANDLES, HARDWARE_POLICY_KEY,
+                                       MAX_CAP_HANDLES, &more, &capability_data);
+    if (tpm_rc)
+    {
+        result = TSS2_APP_RC_BAD_POLICY_STATE;
+        goto end;
+    }
+    for (count = 0; count < capability_data.data.handles.count; count++)
+    {
+        if (capability_data.data.handles.handle[count] == (UINT32)HARDWARE_POLICY_KEY)
+        {
+            hard_key_exist = 1;
+            break;
+        }
+    }
+    if (!hard_key_exist)
+    {
+        result = TSS2_APP_RC_BAD_POLICY_STATE;
+        goto end;
+    }
+
+    /* 4. Check policy state NV index exists */
+    grub_memset (&capability_data, 0, sizeof (TPMS_CAPABILITY_DATA));
+    tpm_rc = grub_tpm2_get_capability (TPM_CAP_HANDLES, NV_INDEX_FIRST,
+                                       MAX_CAP_HANDLES, &more, &capability_data);
+    if (tpm_rc)
+    {
+        result = TSS2_APP_RC_BAD_POLICY_STATE;
+        goto end;
+    }
+    for (count = 0; count < capability_data.data.handles.count; count++)
+    {
+        if (capability_data.data.handles.handle[count] == (UINT32)POLICY_STATE_NV)
+        {
+            nv_exist = 1;
+            break;
+        }
+    }
+    if (!nv_exist)
+    {
+        result = TSS2_APP_RC_BAD_POLICY_STATE;
+        goto end;
+    }
+
+    /* 5. Read the policy state value from NV */
+    session.sessionHandle = TPM_RS_PW;
+    session.nonce.size = 0;
+    grub_memset (session.nonce.buffer, 0, sizeof (TPMU_HA));
+    grub_memset (&session.sessionAttributes, 0, sizeof (TPMA_SESSION));
+    session.hmac.size = 0;
+    grub_memset (session.hmac.buffer, 0, sizeof (TPMU_HA));
+
+    tpm_rc = grub_tpm2_nv_read (POLICY_STATE_NV, POLICY_STATE_NV,
+                                 &session, 4, 0, &out);
+    if (tpm_rc)
+    {
+        result = TSS2_APP_RC_BAD_POLICY_STATE;
+        goto end;
+    }
+
+    unmarshal_uint32 (out.buffer, &policy_state);
+    if (AUDIT_POLICY_EXIST == policy_state)
+        result = TSS2_APP_RC_AUDIT_POLICY_EXIST;
+    else if (SUPERVISORY_POLICY_EXIST == policy_state)
+        result = TSS2_APP_RC_SUPERVISORY_POLICY_EXIST;
+    else
+        result = TSS2_APP_RC_BAD_POLICY_STATE;
+
+end:
+    return result;
+}
+
+/*
+ * check_file_policy_state - read /boot/policy.bin and return the policy type.
+ * Used as fallback when the TPM is not available.
+ */
+grub_err_t
+check_file_policy_state (void)
+{
+    grub_err_t   result = TSS2_APP_RC_POLICY_NOT_EXIST;
+    grub_file_t  file = 0;
+    char        *buf = 0;
+    int          len;
+    int          policy_state = 0;
+
+    file = grub_file_open (POLICYFILE, GRUB_FILE_TYPE_CAT);
+    if (!file || !file->size)
+    {
+        if (grub_errno != GRUB_ERR_NONE)
+            grub_errno = GRUB_ERR_NONE;
+        result = TSS2_APP_RC_POLICY_NOT_EXIST;
+        goto end;
+    }
+
+    len = file->size;
+    buf = grub_malloc (len + 1);
+    if (!buf)
+    {
+        result = TSS2_APP_RC_BAD_POLICY_STATE;
+        goto end;
+    }
+
+    if (grub_file_read (file, buf, len) != len)
+    {
+        result = TSS2_APP_RC_BAD_POLICY_STATE;
+        goto end;
+    }
+
+    unmarshal_uint32 ((unsigned char *)buf, (unsigned int *)&policy_state);
+    if (AUDIT_POLICY_EXIST == policy_state)
+        result = TSS2_APP_RC_AUDIT_POLICY_EXIST;
+    else if (SUPERVISORY_POLICY_EXIST == policy_state)
+        result = TSS2_APP_RC_SUPERVISORY_POLICY_EXIST;
+    else if (POLICY_NOT_EXIST == policy_state)
+        result = TSS2_APP_RC_POLICY_NOT_EXIST;
+    else
+        result = TSS2_APP_RC_BAD_POLICY_STATE;
+
+end:
+    if (buf)
+        grub_free (buf);
+    if (file)
+        grub_file_close (file);
+    return result;
+}
+
+/* -------------------------------------------------------------------------
+ * Encrypted state file reading
+ * ---------------------------------------------------------------------- */
+
+/*
+ * get_hardware_enc_content - read /boot/hardware_state.bin into caller buffer.
+ * The caller must free *out.
+ */
+grub_err_t
+get_hardware_enc_content (unsigned char **out, int *out_len)
+{
+    grub_err_t  result = GRUB_ERR_NONE;
+    grub_file_t file;
+
+    file = grub_file_open (HARDWAREFILE, GRUB_FILE_TYPE_CAT);
+    if (!file || !file->size)
+    {
+        result = TSS2_APP_RC_BAD_NO_ENC_FILE;
+        goto end;
+    }
+
+    *out_len = file->size;
+    *out = grub_malloc (*out_len);
+    if (!*out)
+    {
+        result = GRUB_ERR_OUT_OF_MEMORY;
+        goto end;
+    }
+
+    if (grub_file_read (file, *out, *out_len) != *out_len)
+    {
+        grub_free (*out);
+        *out = NULL;
+        *out_len = 0;
+        result = TSS2_APP_RC_BAD_NO_ENC_FILE;
+    }
+
+end:
+    if (file)
+        grub_file_close (file);
+    return result;
+}
+
+/*
+ * get_software_enc_content - read /boot/software_state.bin into caller buffer.
+ * The caller must free *out.
+ */
+grub_err_t
+get_software_enc_content (unsigned char **out, int *out_len)
+{
+    grub_err_t  result = GRUB_ERR_NONE;
+    grub_file_t file;
+
+    file = grub_file_open (SOFTWAREFILE, GRUB_FILE_TYPE_CAT);
+    if (!file || !file->size)
+    {
+        result = TSS2_APP_RC_BAD_NO_ENC_FILE;
+        goto end;
+    }
+
+    *out_len = file->size;
+    *out = grub_zalloc (*out_len + 1);
+    if (!*out)
+    {
+        result = GRUB_ERR_OUT_OF_MEMORY;
+        goto end;
+    }
+
+    if (grub_file_read (file, *out, *out_len) != *out_len)
+    {
+        grub_free (*out);
+        *out = NULL;
+        *out_len = 0;
+        result = TSS2_APP_RC_BAD_NO_ENC_FILE;
+    }
+
+end:
+    if (file)
+        grub_file_close (file);
+    return result;
+}
+
+/* -------------------------------------------------------------------------
+ * TPM2 key type table for digest sizes
+ * ---------------------------------------------------------------------- */
+
+typedef struct {
+    TPM_ALG_ID  algId;
+    grub_uint16_t size;
+} hash_size_info_t;
+
+static hash_size_info_t hash_sizes[] = {
+    { TPM_ALG_SHA1,    SHA1_DIGEST_SIZE   },
+    { TPM_ALG_SHA256,  SHA256_DIGEST_SIZE },
+#ifdef TPM_ALG_SM3_256
+    { TPM_ALG_SM3_256, SM3_256_DIGEST_SIZE },
+#endif
+    { TPM_ALG_NULL,    0 }
+};
+
+static grub_uint16_t
+get_digest_size (TPM_ALG_ID auth_hash)
+{
+    int i;
+    for (i = 0; hash_sizes[i].algId != TPM_ALG_NULL; i++)
+        if (hash_sizes[i].algId == auth_hash)
+            return hash_sizes[i].size;
+    return 0;
+}
+
+/* -------------------------------------------------------------------------
+ * Hash algorithm selection (prefer SM3 > SHA256 > SHA1)
+ * ---------------------------------------------------------------------- */
+
+static grub_err_t
+check_tpm_hash (TPM_ALG_ID alg)
+{
+    grub_err_t           tpm_rc;
+    TPMI_YES_NO          more;
+    TPMS_CAPABILITY_DATA capability_data;
+    unsigned int         i;
+
+    tpm_rc = grub_tpm2_get_capability (TPM_CAP_ALGS, 0, 64,
+                                       &more, &capability_data);
+    if (tpm_rc)
+        return TSS2_APP_RC_BAD_HASH;
+
+    for (i = 0; i < capability_data.data.algorithms.count; i++)
+        if (capability_data.data.algorithms.algProperties[i].alg == alg)
+            return GRUB_ERR_NONE;
+
+    return TSS2_APP_RC_BAD_HASH;
+}
+
+static grub_err_t
+check_tpm_pcr_bank (TPM_ALG_ID alg)
+{
+    grub_err_t           tpm_rc;
+    TPMI_YES_NO          more;
+    TPMS_CAPABILITY_DATA capability_data;
+    TPMS_PCR_SELECTION   selection;
+    unsigned int         i;
+    int                  j, find = 0, active = 1;
+
+    tpm_rc = grub_tpm2_get_capability (TPM_CAP_PCRS, 0, 64,
+                                       &more, &capability_data);
+    if (tpm_rc)
+        return TSS2_APP_RC_BAD_PCR_BANK;
+
+    for (i = 0; i < capability_data.data.assignedPCR.count; i++)
+    {
+        selection = capability_data.data.assignedPCR.pcrSelections[i];
+        if (selection.hash == alg)
+        {
+            find = 1;
+            break;
+        }
+    }
+
+    if (!find)
+        return TSS2_APP_RC_BAD_PCR_BANK;
+
+    for (j = 0; j < selection.sizeofSelect; j++)
+    {
+        if ((selection.pcrSelect[j] & 0xff) != 0xff)
+        {
+            active = 0;
+            break;
+        }
+    }
+
+    return active ? GRUB_ERR_NONE : TSS2_APP_RC_BAD_PCR_BANK;
+}
+
+static grub_err_t
+get_tpm_supported_hash (TPMI_ALG_HASH *hash_alg)
+{
+    struct { TPM_ALG_ID alg; int support; int active; } candidates[] = {
+#ifdef TPM_ALG_SM3_256
+        { TPM_ALG_SM3_256, 0, 0 },
+#endif
+        { TPM_ALG_SHA256,  0, 0 },
+        { TPM_ALG_SHA1,    0, 0 },
+    };
+    int i, n = (int)(sizeof (candidates) / sizeof (candidates[0]));
+
+    for (i = 0; i < n; i++)
+        if (check_tpm_hash (candidates[i].alg) == GRUB_ERR_NONE)
+            candidates[i].support = 1;
+
+    for (i = 0; i < n; i++)
+    {
+        if (!candidates[i].support)
+            continue;
+        if (check_tpm_pcr_bank (candidates[i].alg) == GRUB_ERR_NONE)
+        {
+            candidates[i].active = 1;
+            *hash_alg = (TPMI_ALG_HASH)candidates[i].alg;
+            return GRUB_ERR_NONE;
+        }
+    }
+
+    return TSS2_APP_RC_BAD_HASH;
+}
+
+/* -------------------------------------------------------------------------
+ * TPM2 Unseal operations
+ * Sequence: StartAuthSession → PolicyPCR → Unseal → FlushContext
+ * ---------------------------------------------------------------------- */
+
+/*
+ * get_hardware_dec_key - unseal the hardware decryption key from the TPM.
+ *
+ * The key is sealed to PCRs 0,1,2,3,6,7 under handle 0x81010101.
+ * If current PCR values match the policy digest recorded at deploy time,
+ * the TPM releases the key; otherwise Unseal fails.
+ *
+ * The caller must free *out.
+ */
+grub_err_t
+get_hardware_dec_key (unsigned char **out, int *out_len)
+{
+    grub_err_t            result = GRUB_ERR_NONE;
+    grub_err_t            tpm_rc;
+    TPMI_DH_OBJECT        tpm_key = TPM_RH_NULL;
+    TPMI_DH_ENTITY        bind = TPM_RH_NULL;
+    TPM2B_NONCE           nonce_caller;
+    TPM2B_ENCRYPTED_SECRET salt;
+    TPM_SE                session_type = TPM_SE_POLICY;
+    TPMT_SYM_DEF          symmetric;
+    TPMI_ALG_HASH         auth_hash;
+    TPMI_SH_AUTH_SESSION  session_handle;
+    TPM2B_NONCE           nonce_tpm;
+    grub_uint16_t         digest_size;
+    int                   i;
+    TPM2B_DIGEST          pcr_digest;
+    TPML_PCR_SELECTION    pcrs;
+    int                   pcr_number[] = { 0, 1, 2, 3, 6, 7, -1 };
+    TPM2B_SENSITIVE_DATA  out_data;
+    TPMS_AUTH_COMMAND     session;
+
+    /* 1. Select the best supported hash algorithm */
+    tpm_rc = get_tpm_supported_hash (&auth_hash);
+    if (tpm_rc)
+    {
+        result = TSS2_APP_RC_BAD_TRUST_STATE;
+        goto end;
+    }
+
+    /* 2. Start a Policy auth session */
+    digest_size = get_digest_size (auth_hash);
+    nonce_caller.size = digest_size;
+    salt.size = 0;
+    symmetric.algorithm = TPM_ALG_NULL;
+    grub_memset (nonce_caller.buffer, 0xA5, digest_size);
+
+    tpm_rc = grub_tpm2_start_auth_session (tpm_key, bind,
+                                            &nonce_caller, &salt,
+                                            session_type, &symmetric,
+                                            auth_hash,
+                                            &session_handle, &nonce_tpm);
+    if (tpm_rc)
+    {
+        result = TSS2_APP_RC_BAD_TRUST_STATE;
+        goto end;
+    }
+
+    /* 3. Bind the session to PCRs 0,1,2,3,6,7 via PolicyPCR */
+    pcr_digest.size = 0;
+    pcrs.count = 1;
+    pcrs.pcrSelections[0].hash = auth_hash;
+    pcrs.pcrSelections[0].sizeofSelect = 3;
+    CLEAR_PCR_SELECT_BITS (pcrs.pcrSelections[0]);
+
+    for (i = 0; pcr_number[i] != -1; i++)
+        SET_PCR_SELECT_BIT (pcrs.pcrSelections[0], pcr_number[i]);
+
+    tpm_rc = grub_tpm2_policy_pcr (session_handle, &pcr_digest, &pcrs);
+    if (tpm_rc)
+    {
+        result = TSS2_APP_RC_BAD_TRUST_STATE;
+        goto flush;
+    }
+
+    /* 4. Unseal the hardware key using the policy session */
+    session.sessionHandle = session_handle;
+    session.nonce.size = 0;
+    grub_memset (session.nonce.buffer, 0, sizeof (TPMU_HA));
+    grub_memset (&session.sessionAttributes, 0, sizeof (TPMA_SESSION));
+    session.hmac.size = 0;
+    grub_memset (session.hmac.buffer, 0, sizeof (TPMU_HA));
+
+    tpm_rc = grub_tpm2_unseal (HARDWARE_POLICY_KEY, &session, &out_data);
+    if (tpm_rc)
+    {
+        result = TSS2_APP_RC_BAD_TRUST_STATE;
+        goto flush;
+    }
+
+    *out_len = out_data.size;
+    *out = grub_zalloc (*out_len);
+    if (!*out)
+    {
+        result = GRUB_ERR_OUT_OF_MEMORY;
+        goto flush;
+    }
+    grub_memcpy (*out, out_data.buffer, out_data.size);
+
+flush:
+    /* Always flush the policy session — limited TPM resource */
+    grub_tpm2_flush_context (session_handle);
+    /* Zero sensitive key material from the stack */
+    grub_memset (&out_data, 0, sizeof (out_data));
+end:
+    return result;
+}
+
+/*
+ * get_software_dec_key - unseal the software decryption key from the TPM.
+ *
+ * The key is sealed to PCRs 8,9,12 under handle 0x81010100.
+ * The caller must free *out.
+ */
+grub_err_t
+get_software_dec_key (unsigned char **out, int *out_len)
+{
+    grub_err_t            result = GRUB_ERR_NONE;
+    grub_err_t            tpm_rc;
+    TPMI_DH_OBJECT        tpm_key = TPM_RH_NULL;
+    TPMI_DH_ENTITY        bind = TPM_RH_NULL;
+    TPM2B_NONCE           nonce_caller;
+    TPM2B_ENCRYPTED_SECRET salt;
+    TPM_SE                session_type = TPM_SE_POLICY;
+    TPMT_SYM_DEF          symmetric;
+    TPMI_ALG_HASH         auth_hash;
+    TPMI_SH_AUTH_SESSION  session_handle;
+    TPM2B_NONCE           nonce_tpm;
+    grub_uint16_t         digest_size;
+    int                   i;
+    TPM2B_DIGEST          pcr_digest;
+    TPML_PCR_SELECTION    pcrs;
+    int                   pcr_number[] = { 8, 9, 12, -1 };
+    TPM2B_SENSITIVE_DATA  out_data;
+    TPMS_AUTH_COMMAND     session;
+
+    /* 1. Select hash algorithm */
+    tpm_rc = get_tpm_supported_hash (&auth_hash);
+    if (tpm_rc)
+    {
+        result = TSS2_APP_RC_BAD_TRUST_STATE;
+        goto end;
+    }
+
+    /* 2. Start Policy auth session */
+    digest_size = get_digest_size (auth_hash);
+    nonce_caller.size = digest_size;
+    salt.size = 0;
+    symmetric.algorithm = TPM_ALG_NULL;
+    grub_memset (nonce_caller.buffer, 0xA5, digest_size);
+
+    tpm_rc = grub_tpm2_start_auth_session (tpm_key, bind,
+                                            &nonce_caller, &salt,
+                                            session_type, &symmetric,
+                                            auth_hash,
+                                            &session_handle, &nonce_tpm);
+    if (tpm_rc)
+    {
+        result = TSS2_APP_RC_BAD_TRUST_STATE;
+        goto end;
+    }
+
+    /* 3. Bind to PCRs 8,9,12 */
+    pcr_digest.size = 0;
+    pcrs.count = 1;
+    pcrs.pcrSelections[0].hash = auth_hash;
+    pcrs.pcrSelections[0].sizeofSelect = 3;
+    CLEAR_PCR_SELECT_BITS (pcrs.pcrSelections[0]);
+
+    for (i = 0; pcr_number[i] != -1; i++)
+        SET_PCR_SELECT_BIT (pcrs.pcrSelections[0], pcr_number[i]);
+
+    tpm_rc = grub_tpm2_policy_pcr (session_handle, &pcr_digest, &pcrs);
+    if (tpm_rc)
+    {
+        result = TSS2_APP_RC_BAD_TRUST_STATE;
+        goto flush;
+    }
+
+    /* 4. Unseal the software key */
+    session.sessionHandle = session_handle;
+    session.nonce.size = 0;
+    grub_memset (session.nonce.buffer, 0, sizeof (TPMU_HA));
+    grub_memset (&session.sessionAttributes, 0, sizeof (TPMA_SESSION));
+    session.hmac.size = 0;
+    grub_memset (session.hmac.buffer, 0, sizeof (TPMU_HA));
+
+    tpm_rc = grub_tpm2_unseal (SOFTWARE_POLICY_KEY, &session, &out_data);
+    if (tpm_rc)
+    {
+        result = TSS2_APP_RC_BAD_TRUST_STATE;
+        goto flush;
+    }
+
+    *out_len = out_data.size;
+    *out = grub_zalloc (*out_len);
+    if (!*out)
+    {
+        result = GRUB_ERR_OUT_OF_MEMORY;
+        goto flush;
+    }
+    grub_memcpy (*out, out_data.buffer, out_data.size);
+
+flush:
+    /* Always flush the policy session — limited TPM resource */
+    grub_tpm2_flush_context (session_handle);
+    /* Zero sensitive key material from the stack */
+    grub_memset (&out_data, 0, sizeof (out_data));
+end:
+    return result;
+}
+
+/*
+ * grub_tlcp_efi_measure - extend a buffer into a TPM2 PCR via EFI TCG2 protocol.
+ *
+ * This is the EFI platform implementation called by grub_measure_configured_files()
+ * in kern/tlcp.c.  Mirrors the logic in commands/efi/tpm.c:grub_tpm_measure()
+ * but lives in the kernel so it is available without loading the tpm module.
+ */
+grub_err_t
+grub_tlcp_efi_measure (unsigned char *buf, grub_size_t size,
+                       grub_uint8_t pcr, const char *description)
+{
+    static grub_guid_t         tpm2_guid = EFI_TPM2_GUID;
+    grub_efi_handle_t          *handles;
+    grub_efi_uintn_t           num_handles;
+    grub_efi_handle_t          tpm_handle;
+    grub_efi_tpm2_protocol_t   *tpm;
+    EFI_TCG2_EVENT             *event;
+    grub_efi_status_t          status;
+    grub_size_t                desc_len;
+
+    handles = grub_efi_locate_handle (GRUB_EFI_BY_PROTOCOL, &tpm2_guid,
+                                      NULL, &num_handles);
+    if (!handles || num_handles == 0)
+        return GRUB_ERR_NONE;   /* TPM absent — silently skip */
+
+    tpm_handle = handles[0];
+    grub_free (handles);
+
+    tpm = grub_efi_open_protocol (tpm_handle, &tpm2_guid,
+                                  GRUB_EFI_OPEN_PROTOCOL_GET_PROTOCOL);
+    if (!tpm)
+        return GRUB_ERR_NONE;
+
+    desc_len = grub_strlen (description);
+    event = grub_zalloc (sizeof (EFI_TCG2_EVENT) + desc_len + 1);
+    if (!event)
+        return grub_error (GRUB_ERR_OUT_OF_MEMORY,
+                           "cannot allocate TPM event buffer");
+
+    event->Header.HeaderSize    = sizeof (EFI_TCG2_EVENT_HEADER);
+    event->Header.HeaderVersion = 1;
+    event->Header.PCRIndex      = pcr;
+    event->Header.EventType     = EV_IPL;
+    event->Size = sizeof (*event) - sizeof (event->Event) + desc_len + 1;
+    grub_strcpy ((char *) event->Event, description);
+
+    status = tpm->hash_log_extend_event (tpm, 0, (grub_addr_t) buf,
+                                         (grub_uint64_t) size, event);
+    grub_free (event);
+
+    if (status != GRUB_EFI_SUCCESS)
+        return grub_error (GRUB_ERR_IO, "TPM2 hash_log_extend_event failed");
+
+    return GRUB_ERR_NONE;
+}
diff --git a/grub-core/kern/efi/tpm2_util/tpm2unmarshal_BASES.c b/grub-core/kern/efi/tpm2_util/tpm2unmarshal_BASES.c
