+        case TPM_RC_POLICY_FAIL + RC_Unseal_itemHandle + TPM_RC_S:
+            Status = grub_error(GRUB_ERR_ACCESS_DENIED, N_("TPM2 Unseal Policy Check Fail"));
+            break;
+        default:
+            Status = grub_error(GRUB_ERR_IO, N_("Command failed"));
+            break;
+    }
+
+    if(Status != GRUB_ERR_NONE)
+    {
+        goto Done;
+    }
+
+    OutData->size = grub_swap_bytes16(RecvBuffer.OutData.size);
+    if(OutData->size > MAX_SYM_DATA)
+    {
+        Status = grub_error(GRUB_ERR_BAD_DEVICE, N_("TPM2  Device response error"));
+        goto Done;
+    }
+
+    grub_memcpy(OutData->buffer, &RecvBuffer.OutData.buffer, OutData->size);
+
+Done:
+    grub_memset(&SendBuffer, 0, sizeof(SendBuffer));
+    grub_memset(&RecvBuffer, 0, sizeof(RecvBuffer));
+
+    return Status;
+}
