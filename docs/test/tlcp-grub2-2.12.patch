diff --git a/include/grub/tlcp.h b/include/grub/tlcp.h
new file mode 100644
index 0000000..9ed7764
--- /dev/null
+++ b/include/grub/tlcp.h
@@ -0,0 +1,84 @@
+/*
+ *  GRUB  --  GRand Unified Bootloader
+ *  iTrustMidware TLCP trusted boot interface for grub2-2.12
+ */
+
+#ifndef GRUB_TLCP_HEADER
+#define GRUB_TLCP_HEADER 1
+
+#include <grub/err.h>
+#include <grub/types.h>
+
+/* Policy state error codes */
+enum TSS2_APP_RESPONSE_CODE {
+    TSS2_APP_RC_BASE,
+    TSS2_APP_RC_BAD_IO,
+    TSS2_APP_RC_BAD_NO_LICENSE,
+    TSS2_APP_RC_BAD_LICENSE_EXPIRED,
+    TSS2_APP_RC_BAD_LICENSE,
+    TSS2_APP_RC_BAD_NO_ABRMD_RUNNING,
+    TSS2_APP_RC_OWNERSHIP_EXIST,
+    TSS2_APP_RC_OWNERSHIP_NOT_EXIST,
+    TSS2_APP_RC_BAD_OWNERAUTH_ERROR,
+    TSS2_APP_RC_BAD_HASH,
+    TSS2_APP_RC_BAD_PCR_BANK,
+    TSS2_APP_RC_BAD_POLICY_STATE,
+    TSS2_APP_RC_POLICY_NOT_EXIST,
+    TSS2_APP_RC_AUDIT_POLICY_EXIST,
+    TSS2_APP_RC_SUPERVISORY_POLICY_EXIST,
+    TSS2_APP_RC_BAD_NO_TRUST_LOG,
+    TSS2_APP_RC_BAD_TRUST_LOG_CONTENT,
+    TSS2_APP_RC_BAD_NO_TRUST_LOG_FILE,
+    TSS2_APP_RC_BAD_NO_ENC_FILE,
+    TSS2_APP_RC_BAD_NO_POLICY_STATE_FILE,
+    TSS2_APP_RC_BAD_KEY,
+    TSS2_APP_RC_BAD_TRUST_STATE,
+    TSS2_APP_RC_END
+};
+
+/* Policy state flags */
+#define POLICY_STATE_TPM_MASK     0x00FF0000u
+#define POLICY_STATE_CHEKC_MASK   0x000000FFu
+#define POLICY_STATE_NONE         0x00000000u
+#define POLICY_STATE_AUDIT        0x00000001u
+#define POLICY_STATE_SUPERVISORY  0x00000002u
+#define POLICY_STATE_TPM_CHECK    0x00010000u
+
+/* TLCP application PCR for configuration file measurement */
+#define TLCP_APPLICATION_PCR      12
+
+/*
+ * Public API called from boot.c
+ * These functions are compiled into the GRUB kernel (not a module).
+ */
+grub_err_t EXPORT_FUNC(grub_tpm_policy_state) (void);
+grub_err_t EXPORT_FUNC(grub_file_policy_state) (void);
+grub_err_t EXPORT_FUNC(grub_tpm_integrity_validation) (int halt);
+grub_err_t EXPORT_FUNC(grub_file_integrity_validation) (int halt);
+grub_err_t EXPORT_FUNC(grub_measure_configured_files) (void);
+
+/*
+ * EFI-specific helpers (implemented in kern/efi/tlcp.c).
+ * Available only on EFI platforms.
+ */
+#if defined (GRUB_MACHINE_EFI)
+grub_err_t check_tpm_policy_state (void);
+grub_err_t check_file_policy_state (void);
+grub_err_t get_software_enc_content (unsigned char **out, int *out_len);
+grub_err_t get_hardware_enc_content (unsigned char **out, int *out_len);
+grub_err_t get_software_dec_key (unsigned char **out, int *out_len);
+grub_err_t get_hardware_dec_key (unsigned char **out, int *out_len);
