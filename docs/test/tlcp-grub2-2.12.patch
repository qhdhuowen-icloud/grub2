diff --git a/grub-core/kern/efi/tpm2integrity.c b/grub-core/kern/efi/tpm2integrity.c
new file mode 100644
index 0000000..23af8d3
--- /dev/null
+++ b/grub-core/kern/efi/tpm2integrity.c
@@ -0,0 +1,138 @@
+#include <grub/err.h>                                                                                               
+#include <grub/misc.h>                                                                                              
+#include <grub/i18n.h>                                                                                              
+#include <grub/types.h>                                                                                             
+#include <grub/tpm20.h>                                                                                             
+#include <grub/efi/api.h>                                                                                           
+#include <grub/efi/tpm.h>                                                                                           
+#include <grub/efi/tpm2tis.h>                                                                                       
+#include <grub/efi/tpm2integrity.h>
+ 
+#pragma pack(1)
+typedef struct {
+    TPM2_COMMAND_HEADER       Header;
+    TPML_PCR_SELECTION        PcrSelectionIn;
+} TPM2_PCR_READ_COMMAND;
+
+typedef struct {
+    TPM2_RESPONSE_HEADER      Header;
+    UINT32                    PcrUpdateCounter;
+    TPML_PCR_SELECTION        PcrSelectionOut;
+    TPML_DIGEST               PcrValues;
+} TPM2_PCR_READ_RESPONSE;
+#pragma pack()
+
+grub_err_t
+grub_tpm2_pcr_read(TPML_PCR_SELECTION        *PcrSelectionIn,
+                   UINT32                    *PcrUpdateCounter,
+                   TPML_PCR_SELECTION        *PcrSelectionOut,
+                   TPML_DIGEST               *PcrValues)
+{
+    grub_efi_status_t              Status;
+    TPM2_PCR_READ_COMMAND          SendBuffer;
+    TPM2_PCR_READ_RESPONSE         RecvBuffer;
+    UINT32                         SendBufferSize;
+    UINT32                         RecvBufferSize;
+    UINT32                         Index;
+    TPML_DIGEST                    *PcrValuesOut;
+    TPM2B_DIGEST                   *Digests;
+    TPM_RC                         ResponseCode;
+
+    SendBuffer.Header.tag = grub_swap_bytes16(TPM_ST_NO_SESSIONS);
+    SendBuffer.Header.commandCode = grub_swap_bytes32(TPM_CC_PCR_Read);
+    
+    SendBuffer.PcrSelectionIn.count = grub_swap_bytes32(PcrSelectionIn->count);
+    for (Index = 0; Index < PcrSelectionIn->count; Index++) 
+    {
+        SendBuffer.PcrSelectionIn.pcrSelections[Index].hash = grub_swap_bytes16(PcrSelectionIn->pcrSelections[Index].hash);
+        SendBuffer.PcrSelectionIn.pcrSelections[Index].sizeofSelect = PcrSelectionIn->pcrSelections[Index].sizeofSelect;
+        grub_memcpy(&SendBuffer.PcrSelectionIn.pcrSelections[Index].pcrSelect, &PcrSelectionIn->pcrSelections[Index].pcrSelect, SendBuffer.PcrSelectionIn.pcrSelections[Index].sizeofSelect);
+    }
+
+    SendBufferSize = sizeof(SendBuffer.Header) + sizeof(SendBuffer.PcrSelectionIn.count) + sizeof(SendBuffer.PcrSelectionIn.pcrSelections[0]) * PcrSelectionIn->count;
+    SendBuffer.Header.paramSize = grub_swap_bytes32 (SendBufferSize);
+    RecvBufferSize = sizeof (RecvBuffer);
+
+    Status = grub_tpm2_submit_command(SendBufferSize, (UINT8 *)&SendBuffer, RecvBufferSize, (UINT8 *)&RecvBuffer);
+    if(Status)
+    {
+        return Status;
+    }
+    
+    ResponseCode = grub_swap_bytes32(RecvBuffer.Header.responseCode);
+    
+    if (RecvBufferSize < sizeof (TPM2_RESPONSE_HEADER)) 
+    {
+        Status = GRUB_ERR_BAD_DEVICE;
+        goto Done;
+    }
+
+    if (ResponseCode != TPM_RC_SUCCESS) 
+    {
+        Status = GRUB_ERR_BAD_ARGUMENT;
+        goto Done;
+    }
+
+    if (RecvBufferSize < sizeof (TPM2_RESPONSE_HEADER) + sizeof(RecvBuffer.PcrUpdateCounter)) 
+    {
+        Status = GRUB_ERR_BAD_DEVICE;
+        goto Done;
+    }
+
+    *PcrUpdateCounter = grub_swap_bytes32(RecvBuffer.PcrUpdateCounter);
+    
+    if (RecvBufferSize < sizeof (TPM2_RESPONSE_HEADER) + sizeof(RecvBuffer.PcrUpdateCounter) + sizeof(RecvBuffer.PcrSelectionOut.count)) 
+    {
+        Status = GRUB_ERR_BAD_DEVICE;
+        goto Done;
+    }
+
+    PcrSelectionOut->count = grub_swap_bytes32(RecvBuffer.PcrSelectionOut.count);
+    if (PcrSelectionOut->count > HASH_COUNT) 
+    {
+        Status = GRUB_ERR_BAD_DEVICE;
+        goto Done;
+    }
+
+    if (RecvBufferSize < sizeof (TPM2_RESPONSE_HEADER) + sizeof(RecvBuffer.PcrUpdateCounter) + sizeof(RecvBuffer.PcrSelectionOut.count) + \ 
+                        sizeof(RecvBuffer.PcrSelectionOut.pcrSelections[0]) * PcrSelectionOut->count) 
+    {
+        Status = GRUB_ERR_BAD_DEVICE;
+        goto Done;
+    }
+    for (Index = 0; Index < PcrSelectionOut->count; Index++) 
+    {
+        PcrSelectionOut->pcrSelections[Index].hash = grub_swap_bytes16(RecvBuffer.PcrSelectionOut.pcrSelections[Index].hash);
+        PcrSelectionOut->pcrSelections[Index].sizeofSelect = RecvBuffer.PcrSelectionOut.pcrSelections[Index].sizeofSelect;
+        if (PcrSelectionOut->pcrSelections[Index].sizeofSelect > PCR_SELECT_MAX) 
+        {
+            Status = GRUB_ERR_BAD_DEVICE;
+            goto Done;
+        }
+        grub_memcpy (&PcrSelectionOut->pcrSelections[Index].pcrSelect, &RecvBuffer.PcrSelectionOut.pcrSelections[Index].pcrSelect, PcrSelectionOut->pcrSelections[Index].sizeofSelect);
+    }
+
+    PcrValuesOut = (TPML_DIGEST *)((UINT8 *)&RecvBuffer + sizeof (TPM2_RESPONSE_HEADER) + sizeof(RecvBuffer.PcrUpdateCounter) + \ 
+                        sizeof(RecvBuffer.PcrSelectionOut.count) + sizeof(RecvBuffer.PcrSelectionOut.pcrSelections[0]) * PcrSelectionOut->count);
+    PcrValues->count = grub_swap_bytes32(PcrValuesOut->count);
+    
+    if (PcrValues->count > 8) 
+    {
+        Status = GRUB_ERR_BAD_DEVICE;
+        goto Done;
+    }
+    Digests = PcrValuesOut->digests;
+    for (Index = 0; Index < PcrValues->count; Index++) 
+    {
+        PcrValues->digests[Index].size = grub_swap_bytes16(Digests->size);
+        if (PcrValues->digests[Index].size > sizeof(TPMU_HA)) 
+        {
+            Status = GRUB_ERR_BAD_DEVICE;
+            goto Done;
+        }
+        grub_memcpy (&PcrValues->digests[Index].buffer, &Digests->buffer, PcrValues->digests[Index].size);
+        Digests = (TPM2B_DIGEST *)((UINT8 *)Digests + sizeof(Digests->size) + PcrValues->digests[Index].size);
+  } 
+Done:
+    return Status;
+}
diff --git a/grub-core/kern/efi/tpm2nvstorage.c b/grub-core/kern/efi/tpm2nvstorage.c
