+#include <grub/err.h>
+#include <grub/misc.h>
+#include <grub/i18n.h>
+#include <grub/types.h>
+#include <grub/tpm20.h>
+#include <grub/efi/api.h>
+#include <grub/efi/tpm.h>
+#include <grub/efi/tpm2tis.h>
+#include <grub/efi/tpm2getcapability.h>
+#include <grub/efi/tpm2/tpm2unmarshal_TPMS_CAPABILITY_DATA.h>
+
+#pragma pack(1)
+
+typedef struct {                                                                                                    
+  TPM2_COMMAND_HEADER       Header;                                                                                 
+  TPM_CAP                   Capability;                                                                             
+  UINT32                    Property;                                                                               
+  UINT32                    PropertyCount;                                                                          
+} TPM2_GET_CAPABILITY_COMMAND;                                                                                      
+                                                                                                                    
+typedef struct {                                                                                                    
+ TPM2_RESPONSE_HEADER      Header;                                                                                  
+  TPMI_YES_NO               MoreData;                                                                               
+  TPMS_CAPABILITY_DATA      CapabilityData;                                                                         
+} TPM2_GET_CAPABILITY_RESPONSE;                                                                                     
+                                                                                                                    
+typedef struct {                                                                                                    
+  TPM2_COMMAND_HEADER       Header;                                                                                 
+  TPMT_PUBLIC_PARMS         Parameters;                                                                             
+} TPM2_TEST_PARMS_COMMAND;                                                                                          
+                                                                                                                    
+typedef struct {                                                                                                    
+  TPM2_RESPONSE_HEADER       Header;                                                                                
+} TPM2_TEST_PARMS_RESPONSE;                                                                                         
+                                                                                                                    
+#pragma pack() 
+
+
+grub_err_t
+grub_tpm2_get_capability(TPM_CAP                   Capability,
+                         UINT32                    Property,
+                         UINT32                    PropertyCount,
+                         TPMI_YES_NO               *MoreData,
+                         TPMS_CAPABILITY_DATA      *CapabilityData)
+{
+    grub_efi_status_t                 Status;
+    TPM2_GET_CAPABILITY_COMMAND       SendBuffer; 
+    TPM2_GET_CAPABILITY_RESPONSE      RecvBuffer;
+    UINT32                            SendBufferSize;
+    UINT32                            RecvBufferSize;
+       
+    // 
+    // Construct command 
+    //
+    SendBuffer.Header.tag = grub_swap_bytes16(TPM_ST_NO_SESSIONS); 
+    SendBuffer.Header.commandCode = grub_swap_bytes32(TPM_CC_GetCapability);                                                        
+    SendBuffer.Capability = grub_swap_bytes32 (Capability); 
+    SendBuffer.Property = grub_swap_bytes32 (Property); 
+    SendBuffer.PropertyCount = grub_swap_bytes32 (PropertyCount);
+                                                                                                                    
+    SendBufferSize = (UINT32) sizeof (SendBuffer);   
+    SendBuffer.Header.paramSize = grub_swap_bytes32 (SendBufferSize); 
+     
+    RecvBufferSize = sizeof(RecvBuffer);                                                                                                               
+    // 
+    // send Tpm command   
+    //
+
+    Status = grub_tpm2_submit_command(SendBufferSize, (UINT8 *)&SendBuffer, RecvBufferSize, (UINT8 *)&RecvBuffer);
+    if(Status)
+    {
+        return Status;
+    }
+
+    if (RecvBufferSize <= sizeof (TPM2_RESPONSE_HEADER) + sizeof (UINT8)) 
+    {
+        return grub_error(GRUB_ERR_UNKNOWN_DEVICE, N_("TPM2 Device error"));
+    } 
+ 
+    if (grub_swap_bytes32(RecvBuffer.Header.responseCode) != TPM_RC_SUCCESS) 
+    {
+        return grub_error(GRUB_ERR_IO, N_("Command failed"));;
+    }
+
+    //
+    // Return the response 
+    //                                                                             
+    *MoreData = RecvBuffer.MoreData;
+    grub_tpm2_unmarshal_TPMS_CAPABILITY_DATA(&RecvBuffer.CapabilityData, CapabilityData);
+    #if 0
+    grub_memcpy(CapabilityData, &RecvBuffer.CapabilityData, RecvBufferSize - sizeof (TPM2_RESPONSE_HEADER) - sizeof (UINT8));
+    #endif
+    return 0;
+}
+
+grub_err_t
+grub_tpm2_get_capability_family_indicator(UINT32 *family_indicator)
+{
+    grub_efi_status_t         status;
+    TPMI_YES_NO               MoreData;
+    TPMS_CAPABILITY_DATA      CapabilityData;
+
+    status = grub_tpm2_get_capability(TPM_CAP_TPM_PROPERTIES,
+                     TPM_PT_FAMILY_INDICATOR,
+                     1,
+                     &MoreData,
+                     &CapabilityData);
+    if(!status)
+    {
+        *family_indicator = CapabilityData.data.tpmProperties.tpmProperty->value;
+    }
+
+    return status;
+}
