+#include <grub/efi/tpm2/tpm2unmarshal_TPML_CCA.h>
+#include <grub/efi/tpm2/tpm2unmarshal_TPML_CC.h>
+#include <grub/efi/tpm2/tpm2unmarshal_TPML_PCR_SELECTION.h>
+#include <grub/efi/tpm2/tpm2unmarshal_TPML_TAGGED_TPM_PROPERTY.h>
+#include <grub/efi/tpm2/tpm2unmarshal_TPML_TAGGED_PCR_PROPERTY.h>
+#include <grub/efi/tpm2/tpm2unmarshal_TPML_ECC_CURVE.h>
+#include <grub/efi/tpm2/tpm2unmarshal_TPMU_CAPABILITIES.h>
+
+grub_size_t grub_tpm2_unmarshal_TPMU_CAPABILITIES(UINT8 *in, TPMU_CAPABILITIES *capabilities, UINT32 selector)
+{
+    grub_size_t    size = 0;
+
+    if( capabilities == 0 )
+    {
+        return 0;
+    }
+
+    switch( selector )
+    {
+#ifdef TPM_CAP_ALGS
+    case TPM_CAP_ALGS:
+            size += grub_tpm2_unmarshal_TPML_ALG_PROPERTY( in + size, &capabilities->algorithms );
+            break;
+#endif
+#ifdef TPM_CAP_HANDLES
+    case TPM_CAP_HANDLES:
+            size += grub_tpm2_unmarshal_TPML_HANDLE( in + size, &capabilities->handles );
+            break;
+#endif
+#ifdef TPM_CAP_COMMANDS
+    case TPM_CAP_COMMANDS:
+            size += grub_tpm2_unmarshal_TPML_CCA( in + size, &capabilities->command );
+            break;
+#endif
+#ifdef TPM_CAP_PP_COMMANDS
+    case TPM_CAP_PP_COMMANDS:
+            size += grub_tpm2_unmarshal_TPML_CC( in + size, &capabilities->ppCommands );
+            break;
+#endif
+#ifdef TPM_CAP_AUDIT_COMMANDS
+    case TPM_CAP_AUDIT_COMMANDS:
+            size += grub_tpm2_unmarshal_TPML_CC( in + size, &capabilities->auditCommands );
+            break;
+#endif
+#ifdef TPM_CAP_PCRS
+    case TPM_CAP_PCRS:
+            size += grub_tpm2_unmarshal_TPML_PCR_SELECTION( in + size, &capabilities->assignedPCR );
+            break;
+#endif
+#ifdef TPM_CAP_TPM_PROPERTIES
+    case TPM_CAP_TPM_PROPERTIES:
+            size += grub_tpm2_unmarshal_TPML_TAGGED_TPM_PROPERTY( in + size, &capabilities->tpmProperties );
+            break;
+#endif
+#ifdef TPM_CAP_PCR_PROPERTIES
+    case TPM_CAP_PCR_PROPERTIES:
+            size += grub_tpm2_unmarshal_TPML_TAGGED_PCR_PROPERTY( in + size, &capabilities->pcrProperties );
+            break;
+#endif
+#ifdef TPM_CAP_ECC_CURVES
+    case TPM_CAP_ECC_CURVES:
+            size += grub_tpm2_unmarshal_TPML_ECC_CURVE( in + size, &capabilities->eccCurves );
+            break;
+#endif
+    }
+
+    return size;
+}
