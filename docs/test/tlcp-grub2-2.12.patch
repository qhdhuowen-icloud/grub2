+
+    *(TPM_SE *)Buffer = SessionType;
+    Buffer++;
+
+    grub_set_unaligned16(Buffer, grub_swap_bytes16(Symmetric->algorithm));
+    Buffer += sizeof(UINT16);
+    switch(Symmetric->algorithm)
+    {
+        case TPM_ALG_NULL:
+            break;
+        case TPM_ALG_AES:
