+/**
+ *  * Set up AES with the key/iv and cipher size.
+ *   */
+void AES_set_key(AES_CTX *ctx, const grub_uint8_t *key,
+                 const grub_uint8_t *iv, AES_MODE mode)
+{
+    int i, ii;
+    grub_uint32_t *W, tmp, tmp2;
+    const unsigned char *ip;
+    int words;
+
+    switch (mode)
+    {
+    case AES_MODE_128:
+        i = 10;
+        words = 4;
+        break;
+
+    case AES_MODE_256:
+        i = 14;
+        words = 8;
+        break;
+
+    default:        /* fail silently */
+        return;
+    }
+
+    ctx->rounds = i;
+    ctx->key_size = words;
+    W = ctx->ks;
+    for (i = 0; i < words; i+=2)
+    {
+        W[i+0]=    ((grub_uint32_t)key[ 0]<<24)|
+                ((grub_uint32_t)key[ 1]<<16)|
+                ((grub_uint32_t)key[ 2]<< 8)|
+                ((grub_uint32_t)key[ 3]    );
+        W[i+1]=    ((grub_uint32_t)key[ 4]<<24)|
+                ((grub_uint32_t)key[ 5]<<16)|
+                ((grub_uint32_t)key[ 6]<< 8)|
+                ((grub_uint32_t)key[ 7]    );
+        key += 8;
+    }
+
+    ip = Rcon;
+    ii = 4 * (ctx->rounds+1);
+    for (i = words; i<ii; i++)
+    {
+        tmp = W[i-1];
+
+        if ((i % words) == 0)
+        {
+            tmp2 =(grub_uint32_t)aes_sbox[(tmp    )&0xff]<< 8;
+            tmp2|=(grub_uint32_t)aes_sbox[(tmp>> 8)&0xff]<<16;
+            tmp2|=(grub_uint32_t)aes_sbox[(tmp>>16)&0xff]<<24;
+            tmp2|=(grub_uint32_t)aes_sbox[(tmp>>24)     ];
+            tmp=tmp2^(((unsigned int)*ip)<<24);
+            ip++;
+        }
+
+        if ((words == 8) && ((i % words) == 4))
+        {
+            tmp2 =(grub_uint32_t)aes_sbox[(tmp    )&0xff]    ;
+            tmp2|=(grub_uint32_t)aes_sbox[(tmp>> 8)&0xff]<< 8;
+            tmp2|=(grub_uint32_t)aes_sbox[(tmp>>16)&0xff]<<16;
+            tmp2|=(grub_uint32_t)aes_sbox[(tmp>>24)     ]<<24;
+            tmp=tmp2;
+        }
+
+        W[i]=W[i-words]^tmp;
+    }
+
+    /* copy the iv across */
+    memcpy(ctx->iv, iv, 16);
+}
+
+/**
+ *  * Change a key for decryption.
+ *   */
+void AES_convert_key(AES_CTX *ctx)
+{
+    int i;
+    grub_uint32_t *k,w,t1,t2,t3,t4;
+
+    k = ctx->ks;
+    k += 4;
+
+    for (i= ctx->rounds*4; i > 4; i--)
+    {
+        w= *k;
+        w = inv_mix_col(w,t1,t2,t3,t4);
+        *k++ =w;
+    }
+}
+
+/**
+ *  * Encrypt a byte sequence (with a block size 16) using the AES cipher.
+ *   */
+void AES_cbc_encrypt(AES_CTX *ctx, const grub_uint8_t *msg, grub_uint8_t *out, int length)
+{
+    int i;
+    grub_uint32_t tin[4], tout[4], iv[4];
+
+    memcpy(iv, ctx->iv, AES_IV_SIZE);
+    for (i = 0; i < 4; i++)
+        tout[i] = ntohl(iv[i]);
+
+    for (length -= AES_BLOCKSIZE; length >= 0; length -= AES_BLOCKSIZE)
+    {
+        grub_uint32_t msg_32[4];
+        grub_uint32_t out_32[4];
+        memcpy(msg_32, msg, AES_BLOCKSIZE);
+        msg += AES_BLOCKSIZE;
+
+        for (i = 0; i < 4; i++)
+            tin[i] = ntohl(msg_32[i])^tout[i];
+
+        AES_encrypt(ctx, tin);
+
+        for (i = 0; i < 4; i++)
+        {
+            tout[i] = tin[i];
+            out_32[i] = htonl(tout[i]);
+        }
+
+        memcpy(out, out_32, AES_BLOCKSIZE);
+        out += AES_BLOCKSIZE;
+    }
+
+    for (i = 0; i < 4; i++)
+        iv[i] = htonl(tout[i]);
+    memcpy(ctx->iv, iv, AES_IV_SIZE);
+}
+
+/**
+ *  * Decrypt a byte sequence (with a block size 16) using the AES cipher.
+ *   */
+void AES_cbc_decrypt(AES_CTX *ctx, const grub_uint8_t *msg, grub_uint8_t *out, int length)
+{
+    int i;
+    grub_uint32_t tin[4], xor[4], tout[4], data[4], iv[4];
+
+    memcpy(iv, ctx->iv, AES_IV_SIZE);
+    for (i = 0; i < 4; i++)
+        xor[i] = ntohl(iv[i]);
+
+    for (length -= 16; length >= 0; length -= 16)
+    {
+        grub_uint32_t msg_32[4];
+        grub_uint32_t out_32[4];
+        memcpy(msg_32, msg, AES_BLOCKSIZE);
+        msg += AES_BLOCKSIZE;
+
+        for (i = 0; i < 4; i++)
+        {
+            tin[i] = ntohl(msg_32[i]);
+            data[i] = tin[i];
+        }
+
+        AES_decrypt(ctx, data);
+
+        for (i = 0; i < 4; i++)
+        {
+            tout[i] = data[i]^xor[i];
+            xor[i] = tin[i];
+            out_32[i] = htonl(tout[i]);
+        }
+
+        memcpy(out, out_32, AES_BLOCKSIZE);
+        out += AES_BLOCKSIZE;
+    }
+
+    for (i = 0; i < 4; i++)
+        iv[i] = htonl(xor[i]);
+    memcpy(ctx->iv, iv, AES_IV_SIZE);
+}
+
+/**
+ *  * Encrypt a single block (16 bytes) of data
+ *   */
+void AES_encrypt(const AES_CTX *ctx, grub_uint32_t *data)
+{
+    /* To make this code smaller, generate the sbox entries on the fly.
+ *      * This will have a really heavy effect upon performance.
+ *           */
+    grub_uint32_t tmp[4];
+    grub_uint32_t tmp1, old_a0, a0, a1, a2, a3, row;
+    int curr_rnd;
+    int rounds = ctx->rounds;
+    const grub_uint32_t *k = ctx->ks;
+
+    /* Pre-round key addition */
+    for (row = 0; row < 4; row++)
+        data[row] ^= *(k++);
+
+    /* Encrypt one block. */
+    for (curr_rnd = 0; curr_rnd < rounds; curr_rnd++)
+    {
+        /* Perform ByteSub and ShiftRow operations together */
+        for (row = 0; row < 4; row++)
+        {
+            a0 = (grub_uint32_t)aes_sbox[(data[row%4]>>24)&0xFF];
+            a1 = (grub_uint32_t)aes_sbox[(data[(row+1)%4]>>16)&0xFF];
+            a2 = (grub_uint32_t)aes_sbox[(data[(row+2)%4]>>8)&0xFF];
+            a3 = (grub_uint32_t)aes_sbox[(data[(row+3)%4])&0xFF];
+
+            /* Perform MixColumn iff not last round */
+            if (curr_rnd < (rounds - 1))
+            {
+                tmp1 = a0 ^ a1 ^ a2 ^ a3;
+                old_a0 = a0;
+                a0 ^= tmp1 ^ AES_xtime(a0 ^ a1);
+                a1 ^= tmp1 ^ AES_xtime(a1 ^ a2);
+                a2 ^= tmp1 ^ AES_xtime(a2 ^ a3);
+                a3 ^= tmp1 ^ AES_xtime(a3 ^ old_a0);
+            }
+
+            tmp[row] = ((a0 << 24) | (a1 << 16) | (a2 << 8) | a3);
+        }
+
+        /* KeyAddition - note that it is vital that this loop is separate from
+           the MixColumn operation, which must be atomic...*/
+        for (row = 0; row < 4; row++)
+            data[row] = tmp[row] ^ *(k++);
+    }
+}
+
+/**
+ *  * Decrypt a single block (16 bytes) of data
+ *   */
+void AES_decrypt(const AES_CTX *ctx, grub_uint32_t *data)
+{
+    grub_uint32_t tmp[4];
+    grub_uint32_t xt0,xt1,xt2,xt3,xt4,xt5,xt6;
+    grub_uint32_t a0, a1, a2, a3, row;
+    int curr_rnd;
+    int rounds = ctx->rounds;
+    const grub_uint32_t *k = ctx->ks + ((rounds+1)*4);
+
+    /* pre-round key addition */
+    for (row=4; row > 0; row--)
+        data[row-1] ^= *(--k);
+
+    /* Decrypt one block */
+    for (curr_rnd = 0; curr_rnd < rounds; curr_rnd++)
+    {
+        /* Perform ByteSub and ShiftRow operations together */
+        for (row = 4; row > 0; row--)
+        {
+            a0 = aes_isbox[(data[(row+3)%4]>>24)&0xFF];
+            a1 = aes_isbox[(data[(row+2)%4]>>16)&0xFF];
+            a2 = aes_isbox[(data[(row+1)%4]>>8)&0xFF];
+            a3 = aes_isbox[(data[row%4])&0xFF];
+
+            /* Perform MixColumn iff not last round */
+            if (curr_rnd<(rounds-1))
+            {
+                /* The MDS cofefficients (0x09, 0x0B, 0x0D, 0x0E)
+                   are quite large compared to encryption; this
+                   operation slows decryption down noticeably. */
+                xt0 = AES_xtime(a0^a1);
+                xt1 = AES_xtime(a1^a2);
+                xt2 = AES_xtime(a2^a3);
+                xt3 = AES_xtime(a3^a0);
+                xt4 = AES_xtime(xt0^xt1);
+                xt5 = AES_xtime(xt1^xt2);
+                xt6 = AES_xtime(xt4^xt5);
+
+                xt0 ^= a1^a2^a3^xt4^xt6;
+                xt1 ^= a0^a2^a3^xt5^xt6;
+                xt2 ^= a0^a1^a3^xt4^xt6;
+                xt3 ^= a0^a1^a2^xt5^xt6;
+                tmp[row-1] = ((xt0<<24)|(xt1<<16)|(xt2<<8)|xt3);
+            }
+            else
+                tmp[row-1] = ((a0<<24)|(a1<<16)|(a2<<8)|a3);
+        }
+
+        for (row = 4; row > 0; row--)
+            data[row-1] = tmp[row-1] ^ *(--k);
+    }
+}
diff --git a/grub-core/kern/tlcp_sha256.c b/grub-core/kern/tlcp_sha256.c
new file mode 100644
index 0000000..d409ada
--- /dev/null
+++ b/grub-core/kern/tlcp_sha256.c
@@ -0,0 +1,239 @@
+#include <grub/misc.h>
+#include <grub/tlcp_sha256.h>
+
+#ifndef NULL
+#define NULL ((void *)0)
+#endif
+
+static const unsigned int g_nK[64] = { 
+    0x428a2f98UL, 0x71374491UL, 0xb5c0fbcfUL, 0xe9b5dba5UL,
+    0x3956c25bUL, 0x59f111f1UL, 0x923f82a4UL, 0xab1c5ed5UL,
+    0xd807aa98UL, 0x12835b01UL, 0x243185beUL, 0x550c7dc3UL,
+    0x72be5d74UL, 0x80deb1feUL, 0x9bdc06a7UL, 0xc19bf174UL,
+    0xe49b69c1UL, 0xefbe4786UL, 0x0fc19dc6UL, 0x240ca1ccUL,
+    0x2de92c6fUL, 0x4a7484aaUL, 0x5cb0a9dcUL, 0x76f988daUL,
+    0x983e5152UL, 0xa831c66dUL, 0xb00327c8UL, 0xbf597fc7UL,
+    0xc6e00bf3UL, 0xd5a79147UL, 0x06ca6351UL, 0x14292967UL,
+    0x27b70a85UL, 0x2e1b2138UL, 0x4d2c6dfcUL, 0x53380d13UL,
+    0x650a7354UL, 0x766a0abbUL, 0x81c2c92eUL, 0x92722c85UL,
+    0xa2bfe8a1UL, 0xa81a664bUL, 0xc24b8b70UL, 0xc76c51a3UL,
+    0xd192e819UL, 0xd6990624UL, 0xf40e3585UL, 0x106aa070UL,
+    0x19a4c116UL, 0x1e376c08UL, 0x2748774cUL, 0x34b0bcb5UL,
+    0x391c0cb3UL, 0x4ed8aa4aUL, 0x5b9cca4fUL, 0x682e6ff3UL,
+    0x748f82eeUL, 0x78a5636fUL, 0x84c87814UL, 0x8cc70208UL,
+    0x90befffaUL, 0xa4506cebUL, 0xbef9a3f7UL, 0xc67178f2UL 
+};
+
+//Function introduced
+#define RMove(x,n)  (((x)>>(n))|((x)<<(32-(n))))
+#define Ch(x,y,z)   (((x)&(y))^((~(x))&(z)))
+#define Maj(x,y,z)  (((x)&(y))^((x)&(z))^((y)&(z)))
+#define E0(x)   (RMove((x),2)^RMove((x),13)^RMove((x),22))
+#define E1(x)   (RMove((x),6)^RMove((x),11)^RMove((x),25))
+#define G0(x)   (RMove((x),7)^RMove((x),18)^((x)>>3))
+#define G1(x)   (RMove((x),17)^RMove((x),19)^((x)>>10))
+
+//A set of operation
+static void sha256_onetime(unsigned int* pnResult, const unsigned char* pbData64Byte)
+{
+    unsigned int a=pnResult[0];
+    unsigned int b=pnResult[1];
+    unsigned int c=pnResult[2];
+    unsigned int d=pnResult[3];
+    unsigned int e=pnResult[4];
+    unsigned int f=pnResult[5];
+    unsigned int g=pnResult[6];
+    unsigned int h=pnResult[7];
+    int i;
+    //Initialization W
+    unsigned int anW[64];
+    for(i=0; i<16; i++)
+    {
+        anW[i] = (pbData64Byte[i*4]<<24)+(pbData64Byte[i*4+1]<<16)+(pbData64Byte[i*4+2]<<8)+pbData64Byte[i*4+3];
+    }
+    for(i=16; i<64; i++)
+        anW[i] = G1(anW[i-2])+anW[i-7]+G0(anW[i-15])+anW[i-16];
+    for(i=0; i<64; i++)
+    {
+        unsigned int nT1 = h+E1(e)+Ch(e,f,g)+g_nK[i]+anW[i];
+        unsigned int nT2 = E0(a)+Maj(a,b,c);
+        h = g;
+        g = f;
+        f = e;
+        e = d+nT1;
+        d = c;
+        c = b;
+        b = a;
+        a = nT1+nT2;
+    }
+    pnResult[0] += a;
+    pnResult[1] += b;
+    pnResult[2] += c;
+    pnResult[3] += d;
+    pnResult[4] += e;
+    pnResult[5] += f;
+    pnResult[6] += g;
+    pnResult[7] += h;
+}
+
+
+//initialization
+int sha256_init(sha256_context* pSha256)
+{
+    if(pSha256 == NULL)
+        return -1;
+    pSha256->strResult[0] = 0;
+    pSha256->anResult[0] = 0x6a09e667UL;
+    pSha256->anResult[1] = 0xbb67ae85UL;
+    pSha256->anResult[2] = 0x3c6ef372UL;
+    pSha256->anResult[3] = 0xa54ff53aUL;
+    pSha256->anResult[4] = 0x510e527fUL;
+    pSha256->anResult[5] = 0x9b05688cUL;
+    pSha256->anResult[6] = 0x1f83d9abUL;
+    pSha256->anResult[7] = 0x5be0cd19UL;
+    pSha256->nSizeH = 0;
+    pSha256->nSizeL = 0;
+    pSha256->bEndSize = 0;
+    return 0;
+}
+
+int sha256_update(sha256_context* pSha256, const void* vpBuffer, unsigned int nBufferSize)
+{
+    const unsigned char* pbBuffer = (const unsigned char*)vpBuffer;
+     if ( (pSha256 == NULL) || (vpBuffer == NULL) || (nBufferSize < 1) )
+     {
+       return -1;
+     }
+
+    if( nBufferSize == 0 ) //changed by wbx 06.22 12:03 "from <= to =="
+        return -1;
+    
+    if(nBufferSize>=(~pSha256->nSizeL))
+        pSha256->nSizeH++;
+    pSha256->nSizeL += nBufferSize;
+    if(pSha256->bEndSize)
+    {
+        int nCopySize;
+        if(nBufferSize<(64u-pSha256->bEndSize))
+            nCopySize = nBufferSize;
+        else
+            nCopySize = 64-pSha256->bEndSize;
+        nBufferSize -= nCopySize;
+        {
+            unsigned char* pb = pSha256->abEnd+pSha256->bEndSize;
+            pSha256->bEndSize += nCopySize;
+            while(nCopySize--)
+                *pb++ = *pbBuffer++;
+        }
+
+        if(pSha256->bEndSize==64)
+        {
+            sha256_onetime(pSha256->anResult, pSha256->abEnd);
+            pSha256->bEndSize = 0;
+        }
+        else
+        {
+            return 0;
+        }
+    }
+
+    {
+        int nGroupCount = nBufferSize/64;
+        while(nGroupCount--)
+        {
+            sha256_onetime(pSha256->anResult, pbBuffer);
+            pbBuffer += 64;
+            nBufferSize -= 64;
+        }
+
+        if(nBufferSize)
+        {
+            unsigned char* pb=pSha256->abEnd;
+            pSha256->bEndSize = (unsigned char)nBufferSize;
+            while(nBufferSize--)
+                *pb++ = *pbBuffer++;//move the last data to the lastgroup(psha256->abEnd)
+        }
+        return 0;
+    }
+}
+
+int sha256_finalize(sha256_context* pSha256,unsigned int * sha256_hash)
+{
+    int i;
+    
+    // parameter check
+    if ( pSha256 == NULL)
+    {
+      return -1;
+    }
+    unsigned int nLen = pSha256->bEndSize;
+    unsigned int nFillSize = 0;
+    int nMod = nLen&63;
+    //Fill first 128
+    pSha256->abEnd[nLen++] = 128u;
+    //Filling
+    if(nMod<56)
+    {
+        nFillSize = 56-nMod-1;
+    }
+    else if(nMod>=56)
+    {
+        for(i=nLen; i<64; i++)
+            pSha256->abEnd[i] = 0;
+        sha256_onetime(pSha256->anResult, pSha256->abEnd);
+        nFillSize = 56;
+        nLen = 0;
+    }
+    while(nFillSize--)
+        pSha256->abEnd[nLen++]=0;
+    //Fill length
+    {
+        unsigned int nL = pSha256->nSizeL;
+        unsigned int nH = (pSha256->nSizeH<<3)+(nL>>29);
+        nL <<= 3;        
+        pSha256->abEnd[56] = (nH>>24)&0xff;
+        pSha256->abEnd[57] = (nH>>16)&0xff;
+        pSha256->abEnd[58] = (nH>>8)&0xff;
+        pSha256->abEnd[59] = (nH>>0)&0xff;
+        pSha256->abEnd[60] = (nL>>24)&0xff;
+        pSha256->abEnd[61] = (nL>>16)&0xff;
+        pSha256->abEnd[62] = (nL>>8)&0xff;
+        pSha256->abEnd[63] = (nL>>0)&0xff;
+    }
+   
+    sha256_onetime(pSha256->anResult, pSha256->abEnd);
+    pSha256->bEndSize = 0;
+    //Translation
+    {
+        char strC[] = "0123456789ABCDEF";
+        char* pc = pSha256->strResult;
+        for(i=0; i<8; i++)
+        {
+            unsigned int nVal = pSha256->anResult[i];
+            *pc++ = strC[(nVal>>28)&0xf];
+            *pc++ = strC[(nVal>>24)&0xf];
+            *pc++ = strC[(nVal>>20)&0xf];
+            *pc++ = strC[(nVal>>16)&0xf];
+            *pc++ = strC[(nVal>>12)&0xf];
+            *pc++ = strC[(nVal>>8)&0xf];
+            *pc++ = strC[(nVal>>4)&0xf];
+            *pc++ = strC[nVal&0xf];
+        }
+        *pc = 0;
+    }
+
+    sha256_hash[0] = pSha256->anResult[0];
+    sha256_hash[1] = pSha256->anResult[1];
+    sha256_hash[2] = pSha256->anResult[2];
+    sha256_hash[3] = pSha256->anResult[3];
+    sha256_hash[4] = pSha256->anResult[4];
+    sha256_hash[5] = pSha256->anResult[5];
+    sha256_hash[6] = pSha256->anResult[6];
+    sha256_hash[7] = pSha256->anResult[7];
+    
+        
+    //successful
+    return 0;
+}
+
+
