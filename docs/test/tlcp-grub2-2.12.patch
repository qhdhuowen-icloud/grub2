+grub_tpm2_flush_context(TPMI_DH_CONTEXT         FlushContext)
+{
+    grub_efi_status_t                Status;
+    TPM2_FLUSH_CONTEXT_COMMAND       SendBuffer;
+    TPM2_FLUSH_CONTEXT_RESPONSE      RecvBuffer;
+    UINT32                           SendBufferSize;
+    UINT32                           RecvBufferSize;
+
+    SendBuffer.Header.tag = grub_swap_bytes16(TPM_ST_NO_SESSIONS);
+    SendBuffer.Header.commandCode = grub_swap_bytes32(TPM_CC_FlushContext);
+
+    SendBuffer.FlushHandle = grub_swap_bytes32(FlushContext);
+   
+    SendBufferSize = (UINT32)sizeof(SendBuffer);
+    SendBuffer.Header.paramSize = grub_swap_bytes32(SendBufferSize);
+    
+    RecvBufferSize = sizeof(RecvBuffer);
+    Status = grub_tpm2_submit_command(SendBufferSize, (UINT8 *)&SendBuffer, RecvBufferSize, (UINT8 *)&RecvBuffer);
+    if(Status)
+    {
+        return Status;
+    }
+
+    if(RecvBufferSize < sizeof(TPM2_RESPONSE_HEADER)) 
+    {
+        return grub_error(GRUB_ERR_BAD_DEVICE, N_("TPM2 Device error"));
+    }
+   
+    if(grub_swap_bytes32(RecvBuffer.Header.responseCode) != TPM_RC_SUCCESS)
+    {
+        return grub_error(GRUB_ERR_IO, N_("Command failed"));
+    }
+
+    return 0;
+}
diff --git a/grub-core/kern/efi/tpm2enhancedauthorization.c b/grub-core/kern/efi/tpm2enhancedauthorization.c
new file mode 100644
index 0000000..384e99f
--- /dev/null
+++ b/grub-core/kern/efi/tpm2enhancedauthorization.c
@@ -0,0 +1,134 @@
+#include <grub/err.h>
+#include <grub/misc.h>
+#include <grub/i18n.h>
+#include <grub/types.h> 
+#include <grub/tpm20.h>
+#include <grub/efi/api.h>
+#include <grub/efi/tpm.h>
+#include <grub/efi/tpm2tis.h>
+#include <grub/efi/tpm2enhancedauthorization.h>
+
+#pragma pack(1)
+typedef struct {
+    TPM2_COMMAND_HEADER        Header;
+    TPMI_SH_POLICY             PolicySession;
+}TPM2_POLICY_GET_DIGEST_COMMAND;
+
+typedef struct {
+    TPM2_RESPONSE_HEADER       Header;
+    TPM2B_DIGEST               PolicyHash;
+}TPM2_POLICY_GET_DIGEST_RESPONSE;
+
+typedef struct {
+    TPM2_COMMAND_HEADER        Header;
+    TPMI_SH_POLICY             PolicySession;
+    TPM2B_DIGEST               PcrDigest;
+    TPML_PCR_SELECTION         Pcrs;
+}TPM2_POLICY_PCR_COMMAND;
+
+typedef struct {
+    TPM2_RESPONSE_HEADER       Header;
+}TPM2_POLICY_PCR_RESPONSE;
+
+#pragma pack()
+
+grub_err_t
+grub_tpm2_policy_get_digest(TPMI_SH_POLICY             PolicySession,
+                            TPM2B_DIGEST               *PolicyHash)
+{
+    grub_efi_status_t                   Status;
+    TPM2_POLICY_GET_DIGEST_COMMAND      SendBuffer;
+    TPM2_POLICY_GET_DIGEST_RESPONSE     RecvBuffer;
+    UINT32                              SendBufferSize;
+    UINT32                              RecvBufferSize;
+
+    SendBuffer.Header.tag = grub_swap_bytes16(TPM_ST_NO_SESSIONS);
+    SendBuffer.Header.commandCode = grub_swap_bytes32(TPM_CC_PolicyGetDigest);
+    
+    SendBuffer.PolicySession = grub_swap_bytes32(PolicySession);
+
+    SendBufferSize = (UINT32) sizeof(SendBuffer);
+    SendBuffer.Header.paramSize = grub_swap_bytes32(SendBufferSize);
+
+    RecvBufferSize = sizeof(RecvBuffer);
+
+    Status = grub_tpm2_submit_command(SendBufferSize, (UINT8 *)&SendBuffer, RecvBufferSize, (UINT8 *)&RecvBuffer);  
+    if(Status)
+    {
+        return Status;
+    }
+   
+    if(grub_swap_bytes32(RecvBuffer.Header.responseCode) != TPM_RC_SUCCESS)
+    {
+        return grub_error(GRUB_ERR_IO, N_("Command failed"));
+    }
+
+    PolicyHash->size = grub_swap_bytes16(RecvBuffer.PolicyHash.size);
+    if(PolicyHash->size > sizeof(TPMU_HA))
+    {
+        return grub_error(GRUB_ERR_UNKNOWN_DEVICE, N_("TPM2 Device response error"));
+    }
+
+    grub_memcpy(PolicyHash->buffer, &RecvBuffer.PolicyHash.buffer, PolicyHash->size);
+    
+    return 0;
+}
+
+grub_err_t
+grub_tpm2_policy_pcr(TPMI_SH_POLICY        PolicySession,
+                     TPM2B_DIGEST          *PcrDigest,
+                     TPML_PCR_SELECTION    *Pcrs)
+{
+    grub_efi_status_t                Status;
+    TPM2_POLICY_PCR_COMMAND          SendBuffer;
+    TPM2_POLICY_PCR_RESPONSE         RecvBuffer;
+    UINT32                           SendBufferSize;
+    UINT32                           RecvBufferSize;
+    UINT8                            *Buffer;
+    UINT32                           Index;
+
+    SendBuffer.Header.tag = grub_swap_bytes16(TPM_ST_NO_SESSIONS);
+    SendBuffer.Header.commandCode = grub_swap_bytes32(TPM_CC_PolicyPCR);
+
+    SendBuffer.PolicySession = grub_swap_bytes32(PolicySession);
+    
+    Buffer = (UINT8 *)&SendBuffer.PcrDigest;
+    grub_set_unaligned16(Buffer, grub_swap_bytes16(PcrDigest->size));
+    Buffer += sizeof(UINT16);
+    grub_memcpy(Buffer, PcrDigest->buffer, PcrDigest->size);
+    Buffer += PcrDigest->size;
+
+    grub_set_unaligned32(Buffer, grub_swap_bytes32(Pcrs->count));
+    Buffer += sizeof(UINT32);
+    for(Index = 0; Index < Pcrs->count; Index++)
+    {
+        grub_set_unaligned16(Buffer, grub_swap_bytes16(Pcrs->pcrSelections[Index].hash));
+        Buffer += sizeof(UINT16);
+        *(UINT8 *)Buffer = Pcrs->pcrSelections[Index].sizeofSelect;
+        Buffer++;
+        grub_memcpy(Buffer, Pcrs->pcrSelections[Index].pcrSelect, Pcrs->pcrSelections[Index].sizeofSelect);
+        Buffer += Pcrs->pcrSelections[Index].sizeofSelect;
+    }
+
+    SendBufferSize = (UINT32)(Buffer - (UINT8 *)&SendBuffer);
+    SendBuffer.Header.paramSize = grub_swap_bytes32(SendBufferSize);
+    
+    RecvBufferSize = sizeof(RecvBuffer);
+    Status = grub_tpm2_submit_command(SendBufferSize, (UINT8 *)&SendBuffer, RecvBufferSize, (UINT8 *)&RecvBuffer);
+    if(Status)                                                                                                      
+    {                                                                                                               
+        return Status;                                                                                              
+    }
+
+    if(RecvBufferSize < sizeof(TPM2_RESPONSE_HEADER))                                                               
+    {                                                                                                               
+        return grub_error(GRUB_ERR_UNKNOWN_DEVICE, N_("TPM2 Device error"));                                        
+    }                                                                                                               
+                                                                                                                    
+    if(grub_swap_bytes32(RecvBuffer.Header.responseCode) != TPM_RC_SUCCESS)                                         
+    {                                                                                                               
+        return grub_error(GRUB_ERR_IO, N_("Command failed"));                                                       
+    }
+
+    return 0;
+}
diff --git a/grub-core/kern/efi/tpm2getcapability.c b/grub-core/kern/efi/tpm2getcapability.c
